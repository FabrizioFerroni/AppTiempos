<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <title>Resumen Semanal de Logs - @Model?.AppName</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <style>
        @@media only screen and (max-width: 600px) {
            .inner-body { width: 100% !important; [cite: 2] }
            .footer { width: 100% !important; [cite: 3] }
        }
    </style>
</head>

<body style="box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #edf2f7; color: #718096; margin: 0; padding: 0; width: 100% !important;">
    <table class="wrapper" width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background-color: #edf2f7; margin: 0; padding: 0; width: 100%;">
        <tr>
            <td align="center">
                <table class="content" width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin: 0; padding: 0; width: 100%;">
                    <tr>
                        <td class="header" style="padding: 25px 0; text-align: center;">
                            <a href="@Model?.UrlApp" style="display: inline-block;">
                                <img src="@Model?.LogoUrl" alt="@Model?.AppName Logo" style="height:auto; width:250px; border:none;"/>
                            </a>
                        </td>
                    </tr>

                    <tr>
                        <td class="body" width="100%" style="background-color: #edf2f7; border: hidden !important;">
                            <table class="inner-body" align="center" width="570" cellpadding="0" cellspacing="0" role="presentation" style="background-color: #ffffff; border-radius: 2px; margin: 0 auto; width: 570px; box-shadow: 0 2px 0 rgba(0, 0, 150, 0.025);"> 
                                <tr>
                                    <td class="content-cell" style="padding: 32px;">
                                        <h1 style="color: #3d4852; font-size: 18px; font-weight: bold; margin-top: 0; text-align: left;">
                                            Reporte de Auditoría Semanal 
                                        </h1>
                                        
                                        <p style="font-size: 16px; line-height: 1.5em; color: #718096; text-align: left;">
                                            Hola, se ha generado el respaldo automático de los archivos de log correspondientes a la última semana de actividad en <strong>@Model?.AppName</strong>. 
                                        </p>

                                        <div style="background-color: #f8fafc; padding: 15px; border-radius: 4px; margin: 20px 0;">
                                            <p style="margin: 0; font-size: 14px;">
                                                <strong>Detalles del envío:</strong><br />
                                                • Fecha: @Model?.FechaEnvio<br />
                                                • Servidor: @Model?.MachineName <br / >
                                                • Archivos incluidos: @Model?.ArchivosCount
                                            </p>
                                        </div>

                                        <p style="font-size: 16px; line-height: 1.5em; color: #718096; text-align: left;">
                                            Encontrarás el archivo <strong>.zip</strong> adjunto a este correo. Se recomienda descargar y almacenar este archivo para futuras revisiones técnicas. 
                                        </p>

                                        <p style="font-size: 16px; line-height: 1.5em; margin-top: 25px;">
                                            Saludos,<br />
                                            Sistema de Tareas Programadas 
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <tr>
                        <td>
                            <table class="footer" align="center" width="570" cellpadding="0" cellspacing="0" role="presentation">
                                <tr>
                                    <td class="content-cell" align="center" style="padding: 24px;">
                                        <p style="font-size:12px; color:#b0adc5; text-align:center; margin:0;">
                                            © @Model?.Year <strong>@Model?.AppName</strong>. Todos los derechos reservados. 
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>