    <ItemGroup>
        <Content Update="Files\MailTemplates\*.cshtml">
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </Content>
        <Content Update="Files\MailTemplates\sendInvitation.cshtml">
          <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </Content>
        <Content Update="Files\colors.json">
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
