    <ItemGroup>
      <ProjectReference Include="..\AppTiemposV3.ServiceDefaults\AppTiemposV3.ServiceDefaults.csproj" />
      <ProjectReference Include="..\AppTiemposV3.SharedClases\AppTiemposV3.SharedClases.csproj" />
    </ItemGroup>

	<Target Name="GenerateColorsJson" BeforeTargets="Build">
		<PropertyGroup>
			<PathSep Condition="'$(OS)' == 'Windows_NT'">\</PathSep>
			<PathSep Condition="'$(OS)' != 'Windows_NT'">/</PathSep>

			<ConsoleProject>..$(PathSep)AppTiemposV3.Console$(PathSep)AppTiemposV3.Console.csproj</ConsoleProject>
			<OutputPathJson>Files$(PathSep)colors.json</OutputPathJson>
		</PropertyGroup>

		<Message Importance="high" Text="Generando colors.json en $(OS) usando: $(ConsoleProject)" />

		<Exec Command="dotnet run --project &quot;$(ConsoleProject)&quot; &quot;$(OutputPathJson)&quot;" />
	</Target>

    <!--<Target Name="GenerateColorsJson" BeforeTargets="Build">
