@using AppTiemposV3.Web.Authentication
@using Microsoft.AspNetCore.Components.Authorization
@using AppTiemposV3.Web.Pages
@inject NavigationManager Router
@inject AuthenticationStateProvider AuthStateProvider
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        @* <div class="top-row px-4"> *@
        @*     <AuthorizeView> *@
        @*         <Authorized> *@
        @*             <div class="dropdown"> *@
        @*                 <button class="btn btn-transparent dropdown-toggle drop-per" type="button" data-bs-toggle="dropdown" aria-expanded="false"> *@
        @*                     Hola, <span class="text-danger">@context.User.Identity!.Name!.Split()[0]</span> *@
        @*                 </button> *@
        @*                 <ul class="dropdown-menu"> *@
        @*                     <li><a class="dropdown-item ml-0" href="#">Profile</a></li> *@
        @*                     <li><hr class="dropdown-divider" /></li> *@
        @*                     <li><a class="dropdown-item ml-0" @onclick="Logout"> *@
        @*                         <i class="bi bi-box-arrow-in-left"></i> *@
        @*                         Logout *@
        @*                     </a></li> *@
        @*                 </ul> *@
        @*             </div> *@
        @*         </Authorized> *@
        @*     </AuthorizeView> *@
        @* </div> *@
        <article class="content px-4">
            <AuthorizeView>
                <Authorized>
                    @Body
                </Authorized>
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
                <Authorizing>
                    <div class="fullscreen-loader">
                        <div class="spinner-border text-danger"></div>
                        <p>Validando autorización...</p>
                    </div>
                </Authorizing>
            </AuthorizeView>
        </article>
    </main>
</div>


<div id="blazor-error-ui">
    Se ha producido un error.
    <a href="" class="reload">Recargar</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private async Task Logout()
    {
        CustomAuthenticationProvider? customAuthStateProvider = (CustomAuthenticationProvider)AuthStateProvider;
        await customAuthStateProvider.UpdateAuthenticationState(null!);
        Router.NavigateTo("/");
    }
}
