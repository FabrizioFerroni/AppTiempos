<div class=@($"{positionBanner} top-0 left-0 right-0 z-[9999] {ColorService.GetCurrentColor().Gradient} text-white shadow-lg")>
    <div class="mx-auto px-4 py-2">
        <div class="flex items-center justify-between gap-4">
            <div class="flex items-center gap-6 flex-wrap flex-1">
                <div class="flex items-center gap-2">
                    <Calendar Class="w-4 h-4" />
                    <span class="font-semibold text-sm md:text-base">
                        Semana con Sábado Laboral: @SemanaWork - @DayWork @* 02/02/2026 - 07/02/2026 *@
                    </span>
                </div>
                <div class="flex items-center gap-2">
                    <Clock Class="w-4 h-4" />
                    <span class="text-sm">
                        Horario: @HorasWork @* 08:00 - 12:00 *@
                    </span>
                </div>
                <div class="bg-white/20 px-3 py-0.5 rounded-full text-sm font-medium">
                    @($"{TotalHsWork}h")    
                </div>
            </div>
            <Button
                Variant="ghost"
                Size="sm"
                Class="text-white hover:bg-white/20 hover:text-white p-1 h-auto"
                OnClick="() => CloseBanner()"
          >
            <Close Class="w-5 h-5" />
          </Button>
        </div>
    </div>
</div>
