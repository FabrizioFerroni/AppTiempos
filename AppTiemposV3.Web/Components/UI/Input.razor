<input
    @ref="_inputRef"
    type="@Type"
    class="@GetClasess()"
    style="@Style"
    id="@Id"
    name="@Name"
    placeholder="@Placeholder"
    disabled="@Disabled"
    accept="@Accept"
    autocomplete="@Autocomplete"
    autocapitalize="@Autocapitalize"
    autofocus="@Autofocus"
    required="@Required"
    minlength="@MinLength"
    maxlength="@MaxLength"
    min="@Min"
    max="@Max"
    pattern="@Pattern"
    inputmode="@InputMode"
    @bind="CurrentValue"
    @bind:event="oninput"
    @onclick="OnClick"
    @attributes="GetBooleanAttributes().Concat(AdditionalAttributes ?? new()).ToDictionary(k => k.Key, v => v.Value)"
    />