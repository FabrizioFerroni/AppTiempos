@if (Type == "file")
{
    <div class="@GetClasess()  relative w-full ">
        <span class="flex-grow text-sm text-gray-900 dark:text-white truncate">
            @(string.IsNullOrEmpty(fileName) ? "Ningún archivo seleccionado" : fileName)
        </span>

        <label for="@Id" class="text-gray-500 hover:text-gray-800 bg-transparent dark:text-gray-100 dark:hover:text-gray-400  text-sm font-medium px-3 py-1 border-0 cursor-pointer">
            <FolderOpen Class="w-4 h-4" />
        </label>

        <InputFile id="@Id" class="hidden" OnChange="HandleFileSelected" />
    </div>
}
else
{

    <input
    @ref="_inputRef"
    type="@Type"
    class="@GetClasess()"
    style="@Style"
    id="@Id"
    name="@Name"
    placeholder="@Placeholder"
    disabled="@Disabled"
    accept="@Accept"
    autocomplete="@Autocomplete"
    autocapitalize="@Autocapitalize"
    autofocus="@Autofocus"
    required="@Required"
    minlength="@MinLength"
    maxlength="@MaxLength"
    min="@Min"
    max="@Max"
    step="@Step"
    pattern="@Pattern"
    inputmode="@InputMode"
    @bind="CurrentValue"
    @bind:event="oninput"
    @onclick="OnClick"
    @attributes="GetBooleanAttributes().Concat(AdditionalAttributes ?? new()).ToDictionary(k => k.Key, v => v.Value)"
    />
}