<input 
    type="@Type"
    class="@GetClasess()"
    id="@Id"
    name="@Name"
    placeholder="@Placeholder"
    disabled="@Disabled"
    accept="@Accept"
    autocomplete="@Autocomplete"
    autocapitalize="@Autocapitalize"
    autofocus="@Autofocus"
    required="@Required"
    value="@Value"
    @oninput="OnValueChanged"
    @onclick="OnClick"
    @attributes="GetBooleanAttributes()"
    />