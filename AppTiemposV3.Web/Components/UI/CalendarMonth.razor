@using System.Globalization

<div class="p-3 border rounded-lg dark:border-gray-700 bg-gray-50 dark:bg-gray-900">
    <div class="flex justify-between items-center mb-2">
        <Button OnClick="PreviousMonth" Class="px-2 py-1 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded cursor-pointer">
            <ChevronLeft Class="w-4 h-4 rtl:rotate-180" />
        </Button>
        <div class="font-semibold text-center capitalize select-none">
            @CurrentMonth.ToString("MMMM yyyy", new CultureInfo("es-ES"))
        </div>
        <Button OnClick="NextMonth" Class="px-2 py-1 text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded cursor-pointer">
            <ChevronRight Class="w-4 h-4 rtl:rotate-180" />
        </Button>
    </div>

    <div class="grid grid-cols-7 text-xs text-gray-500 mb-1 text-center">
        @foreach (string day in new[] { "L", "M", "X", "J", "V", "S", "D" })
        {
            <div>@day</div>
        }
    </div>

    <div class="grid grid-cols-7 gap-1 text-center text-sm">
        @foreach (DateTime? d in GetDaysForMonth())
        {
            if (d == null)
            {
                <div></div>
            }
            else
            {
                bool isDisabled = !AllowFutureDates && d > DateTime.Today;
                string? cls = GetDayClass(d.Value, isDisabled);
                <Button Size="sm" Variant="ghost" Disabled="@isDisabled"
                        Class="@($"{cls} {(isDisabled ? "cursor-not-allowed" : "cursor-pointer")}")"
                        OnClick="(() => OnDayClick(d.Value))">
                    @d.Value.Day
                </Button>
            }
        }
    </div>
</div>