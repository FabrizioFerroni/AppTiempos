<div class="sticky top-0 z-40 w-full border-b border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/90 backdrop-blur-sm">
    @*  *@
    @* border-gray-200/50 dark:border-gray-700/50 bg-white/80 dark:bg-gray-900/80 *@
    <div class="flex h-16 items-center justify-between px-6">
        <!-- IZQUIERDA -->
        <div class="flex items-center gap-4">
            <SidebarTrigger Class="text-gray-900 dark:text-white"/>
            <Separator Orientation="vertical" Class="h-6"/>
            <div>
                <h1 class="text-xl font-semibold text-gray-900 dark:text-white">@Title</h1>
                @if (!string.IsNullOrEmpty(Subtitle))
                {
                    <p class="text-sm text-gray-600 dark:text-gray-300">@Subtitle</p>
                }
            </div>
        </div>

        <!-- DERECHA -->
        <div class="flex items-center gap-2">
            @ChildContent
            @if (ChildContent is not null)
            {
                <Separator Orientation="vertical" Class="h-6"/>
            }
            <div class="flex items-center gap-1 text-gray-900 dark:text-white">
                <NotificationCenter/>
                <ColorPicker/>
                <ThemeToggle/>
            </div>
        </div>
    </div>
</div>