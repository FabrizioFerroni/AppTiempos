<textarea
    class="@GetClasess()"
    id="@Id"
    name="@Name"
    placeholder="@Placeholder"
    disabled="@Disabled"
    autocomplete="@Autocomplete"
    autocapitalize="@Autocapitalize"
    autofocus="@Autofocus"
    required="@Required"
    @oninput="OnValueChanged"
    @onclick="OnClick"
    @attributes="GetBooleanAttributes()"
>@Value</textarea>
