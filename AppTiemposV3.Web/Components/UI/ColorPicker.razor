@using AppTiemposV3.SharedClases.GenericModels
<el-dropdown class="inline-block">
    <Button Class="relative cursor-pointer" Size="sm" Variant="ghost">
        <Palette Class="h-4 w-4" />
        <span class="sr-only">Cambiar color</span>
    </Button>

    <el-menu anchor="bottom end" popover class="mt-3 w-56 origin-top-right  rounded-md bg-white/80 dark:bg-gray-800 shadow-lg outline-1 outline-black/5 dark:outline-1 dark:-outline-offset-1 dark:outline-white/10 transition transition-discrete [--anchor-gap:--spacing(2)] data-closed:scale-95 data-closed:transform data-closed:opacity-0 data-enter:duration-100 data-enter:ease-out data-leave:duration-75 data-leave:ease-in">
        <div class="py-1">
            <span class="block px-4 py-2 text-sm dark:text-gray-300 dark:focus:bg-white/5 dark:focus:text-white focus:outline-hidden">Esquema de Colores</span>
            <div class="space-y-2">
                @foreach (ColorModel? color in ColorService.Colors)
                {
                    <div id="@color.Id" class="px-2">
                        <a href="javascript:void(0);" @onclick="() => SetColor(color.Name)" class="@GetButtonClass(color)">
                            <div class="w-4 h-4 rounded-full @(color.Gradient)"></div>
                            @color.Name
                        </a>
                    </div>
                }
            </div>
        </div>
    </el-menu>
</el-dropdown>