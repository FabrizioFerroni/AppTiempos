@if (IsOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-[rgb(31_41_55_/_0.75)] dark:bg-[rgb(17_24_39_/_0.75)]"></div>

        <!-- Contenido -->
        <div class="relative bg-white dark:bg-gray-800 rounded-lg text-center shadow-xl p-6 max-w-lg w-full z-10">
            <div class="flex flex-col items-center py-8">
                <LoaderCircle class="w-16 h-16 mb-4 animate-spin text-gray-900 dark:text-gray-100" />
                <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">
                    Cargando @Modulo
                </h3>
                <p class="text-gray-500 dark:text-gray-400 animate-pulse">
                    Espere unos segundos ...
                </p>
            </div>
        </div>
    </div>
}