@using AppTiemposV3.SharedClases.GenericModels
@using static AppTiemposV3.SharedClases.Utilidades.DateHelpers

<el-dropdown class="inline-block">
    <Button Class="relative cursor-pointer focus:ring-0 ring-0" Size="sm" Variant="ghost">
        <Bell Class="h-4 w-4" />
        @if (UnreadCount > 0)
        {
            <Badge Variant="destructive" Class="absolute -top-1 -right-1 h-5 w-5 rounded-full bg-red-600 p-0 flex items-center justify-center text-xs">
                @(UnreadCount > 9 ? "9+" : UnreadCount.ToString())
            </Badge>
        }
        <span class="sr-only">
                Notificaciones
        </span>
    </Button>

    <el-menu anchor="bottom end" popover class="mt-3 w-64 origin-top-right  rounded-md bg-white/80 dark:bg-gray-800 shadow-lg outline-1 outline-black/5 dark:outline-1 dark:-outline-offset-1 dark:outline-white/10 transition transition-discrete [--anchor-gap:--spacing(2)] data-closed:scale-95 data-closed:transform data-closed:opacity-0 data-enter:duration-100 data-enter:ease-out data-leave:duration-75 data-leave:ease-in">
        <div class="py-1">
            <div class="flex items-center justify-between pe-4">
                <span class="block px-4 py-2 text-sm  text-gray-500 dark:text-gray-300 dark:focus:bg-white/5 dark:focus:text-white focus:outline-hidden">
                    Notificaciones
                </span>
                @if (UnreadCount > 0)
                {
                    <Button Variant="ghost" Size="sm" OnClick="() => MarkAllAsRead()" Class="text-xs cursor-pointer ">
                        <CheckCheck Class="dark:text-gray-300 text-gray-600 h-4 w-4"/>
                    </Button>
                }
            </div>
            <div class="space-y-2">
                @if (DeletedCount == 0)
                {
                    <div class="text-center py-6">
                        <Bell Class="h-8 w-8 text-gray-400 mx-auto mb-2" />
                        <p class="text-sm text-gray-500">
                            No hay notificaciones
                        </p>
                    </div>
                }
                else
                {
                    @foreach (NotificationModel notif in Notifications)
                    {
                        <div id="@notif.Id" class="@GetNotificationClasses(notif) mx-4 my-2">
                            <div class="flex items-start gap-3 ">
                                <!-- Icono -->
                                @GetNotificationIcon(notif.Type)
                                <div class="flex-1 min-w-0">
                                    <div class="flex justify-between items-center gap-3">
                                        <h4 class="text-sm font-medium truncate text-gray-700 dark:text-gray-300">
                                            @notif.Title
                                        </h4>
                                        <div class="flex items-center gap-1">
                                            <span class="text-xs text-gray-700 dark:text-gray-300 flex items-center gap-1">
                                                <Clock Class="h-3 w-3" />
                                                @FormatTimestamp(notif.Date)
                                            </span>
                                            <button @onclick="() => RemoveNotification(notif.Id)"
                                                    class="h-6 w-6 p-0 text-gray-700 dark:text-gray-300 cursor-pointer">
                                                <Close Class="h-3 w-3 text-gray-700 dark:text-gray-300" />
                                                <span class="sr-only">Cerrar</span>
                                            </button>
                                        </div>
                                    </div>
                                    <p class="text-xs text-gray-700 dark:text-gray-300 mt-1">
                                        @notif.Message
                                    </p>
                                    <div class="flex justify-between mt-2">
                                        @if (!string.IsNullOrEmpty(notif.ActionUrl))
                                        {
                                            <Enlace Href="@notif.ActionUrl" Class="text-xs text-blue-600 hover:underline cursor-pointer">
                                                Ver más
                                            </Enlace>
                                        }
                                        @if (!notif.IsRead)
                                        {
                                            <a href="javascript:void(0);" @onclick="() => MarkAsRead(notif.Id)" class="ml-auto text-xs text-gray-700 dark:text-gray-300 hover:underline flex gap-1 cursor-pointer items-center">
                                                <Check Class="h-3 w-3 mr-1" />
                                                Marcar como leída
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    
                }
            </div>
        </div>
    </el-menu>
</el-dropdown>