<el-dialog id=@($"{Id}")>
  <dialog id=@($"{Method}-{IdElement}") aria-labelledby="dialog-title" class="fixed inset-0 size-auto max-h-none max-w-none overflow-y-auto bg-transparent backdrop:bg-transparent">
    <el-dialog-backdrop class="fixed inset-0 bg-[rgb(31_41_55_/_0.75)] dark:bg-[rgb(17_24_39_/_0.75)] transition-opacity data-closed:opacity-0 data-enter:duration-300 data-enter:ease-out data-leave:duration-200 data-leave:ease-in"></el-dialog-backdrop>

    <div tabindex="0" class="flex min-h-full items-end justify-center p-4 text-center focus:outline-none sm:items-center sm:p-0">
      <el-dialog-panel class="relative transform overflow-hidden rounded-lg bg-white dark:bg-gray-800 text-left shadow-xl outline -outline-offset-1 dark:outline-white/10 transition-all data-closed:translate-y-4 data-closed:opacity-0 data-enter:duration-300 data-enter:ease-out data-leave:duration-200 data-leave:ease-in sm:my-8 sm:w-full sm:max-w-lg data-closed:sm:translate-y-0 data-closed:sm:scale-95">
        <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
          <div class="sm:flex sm:items-start">
            <div class="mx-auto flex size-12 shrink-0 items-center justify-center rounded-full bg-red-100 dark:bg-red-500/10 sm:mx-0 sm:size-10">
              <AlertTriangle Class="size-6 text-red-600 dark:text-red-400"/>
            </div>
            <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
              <h3 id="dialog-title" class="text-base font-semibold text-gray-900 dark:text-white">
                @Title
              </h3>
              <div class="mt-2">
                <p class="text-sm text-gray-500 dark:text-gray-400">
                    @if (!string.IsNullOrEmpty(Subtitle))
                    {
                        @Subtitle
                    }
                    else if (SubtitleHtml != null)
                    {
                        @SubtitleHtml
                    }
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/25 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6">
          <Button
            Type="button"
            Variant=""
            Size=""
            Id=@($"delete-button-modal-{Id}")
            Command="close"
            CommandFor=@($"{Method}-{IdElement}")
            OnClick="async () => await OnConfirm.InvokeAsync(IdElement)"
            Class="cursor-pointer inline-flex w-full justify-center rounded-md bg-red-600 dark:bg-red-500 px-3 py-2 text-sm font-semibold text-white hover:bg-red-500 dark:hover:bg-red-400 sm:ml-3 sm:w-auto"
            >
            @TitleBtn
          </Button>
          
          <Button
            Type="button"
            Variant=""
            Size=""
            Id=@($"cancel-button-modal-{Id}")
            Command="close"
            CommandFor=@($"{Method}-{IdElement}")
            Class="cursor-pointer mt-3 inline-flex w-full justify-center rounded-md bg-white dark:bg-white/10 px-3 py-2 text-sm font-semibold text-gray-900 dark:text-white inset-ring inset-ring-gray-300 dark:inset-ring-white/5 hover:bg-gray-50 dark:hover:bg-white/20 sm:mt-0 sm:w-auto"
          >
            Cancelar
          </Button>
        </div>
      </el-dialog-panel>
    </div>
  </dialog>
</el-dialog>