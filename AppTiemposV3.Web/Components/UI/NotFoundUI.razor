<section class="relative flex flex-col select-none items-center justify-center min-h-screen overflow-hidden bg-gradient-to-br from-indigo-200 via-purple-300 to-pink-200 dark:from-gray-900 dark:via-gray-800 dark:to-gray-700">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;utf8,<svg xmlns=&quot;http://www.w3.org/2000/svg&quot; width=&quot;20&quot; height=&quot;20&quot;><circle cx=&quot;1&quot; cy=&quot;1&quot; r=&quot;1&quot; fill=&quot;%23999&quot;/></svg>')] 
                opacity-10 dark:opacity-20"></div>

    <div class="relative z-10 py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6 text-center">
        <h1 class=@($"mb-4 text-7xl tracking-tight font-extrabold lg:text-9xl text-transparent bg-clip-text drop-shadow-lg animate-gradient {ColorService.GetCurrentColor().Gradient}")>
            404
        </h1>
        <p class="mb-4 text-3xl tracking-tight font-bold text-gray-900 dark:text-gray-100 md:text-4xl">
            Página no encontrada
        </p>
        <p class="mb-6 text-lg font-light text-gray-500 dark:text-gray-400">
            Lo sentimos, no encontramos la página que buscabas.
        </p>

        <Button OnClick="GoBack" Class=@($"px-3 py-2 text-sm rounded-lg transition-all duration-300 transform hover:scale-105 hover:shadow-lg {ColorService.GetButtonClassess()}")>
            <ArrowLeft Class="h-4 w-4 mr-2"/>
            Volver atrás
        </Button>
    </div>
</section>
