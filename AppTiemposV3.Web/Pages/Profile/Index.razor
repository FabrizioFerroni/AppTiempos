                                    </TableCell>
                                    <TableCell>
                                        <div class="flex items-center gap-2">
                                            <Monitor class="h-4 w-4 text-gray-500 dark:text-gray-400" />
                                            Chrome en Windows
                                        </div>
                                    </TableCell>
                                    <TableCell>
                                        <div class="flex items-center gap-2">
                                            <MapPin Class="h-4 w-4 text-gray-500 dark:text-gray-400" />
                                            Buenos Aires, Argentina
                                        </div>
                                    </TableCell>
                                    <TableCell Class="text-gray-500 dark:text-gray-400">
                                        192.168.1.45
                                    </TableCell>
                                    <TableCell>
                                        <Badge Class="bg-green-100 text-green-800 hover:bg-green-100">
                                            Exitoso
                                        </Badge>
                                    </TableCell>
                                </TableRow>
                                
