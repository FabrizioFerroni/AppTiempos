                </CardHeader>
                <CardContent>
                    <div class="flex items-center justify-between">
                        <div class="space-y-1">
                            <h4 class="text-sm font-medium">
                                Habilitar 2FA
                            </h4>
                            <p class="text-sm text-gray-500 dark:text-gray-400">
                                Agrega una capa extra de seguridad a tu cuenta
                            </p>
                        </div>
                        <Switch Checked="twoFactorEnabled" CheckedChanged="HandleResolveCheck" Disabled="IsLoading2fa"/>
                    </div>

                    @if (twoFactorEnabled)
                    {
                        <div class="mt-4 p-4 bg-green-50 border border-green-200 dark:bg-green-900/20 dark:border-green-500/40 rounded-lg">
                            <p class="text-sm text-green-800 dark:text-green-300">
                                ✅ La autenticación de dos factores está activada. Tu cuenta está más segura.
                            </p>
                        </div>
                    }
                </CardContent>
            </Card>

            @* Ver luego cuando este implementado lo de auditoria *@
