                             class="p-4 rounded-lg border bg-white border-gray-200 dark:bg-gray-700 dark:border-gray-600">
                            <div class="flex items-start justify-between">
                                <div class="flex items-start gap-3">
                                    <Monitor Class="h-5 w-5 text-gray-500 dark:text-gray-400 mt-1" />
