                            <TableBody Class="[&_tr]:border-b-gray-200 [&_tr]:dark:border-b-gray-700">
                                <TableRow Id="@_guidBorrar.ToString()" Class="hover:bg-gray-400 dark:hover:bg-gray-700">
                                    <TableCell Class="font-medium">
                                        <div class="flex items-center gap-2">
                                            <Clock class="h-4 w-4 text-gray-500 dark:text-gray-400" />
                                            2025-01-15 09:23
