@using AppTiemposV3.SharedClases.Enums
@page "/app/perfil"

<PageTitle>Mi perfil | TimeTracker Pro</PageTitle>

<div class="flex flex-col w-full select-none">
    <Navbar Title="Mi Perfil" Subtitle="Gestiona tu información personal y configuración de seguridad" OnToggleSidebar="HandleSidebarToggle" />
    @if (IsLoadingData)
    {
        <div class="flex flex-col items-center justify-center py-12 text-center">
            <LoaderCircle Class="w-16 h-16 mb-4 animate-spin"/>
            <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">
                Cargando datos del usuario
            </h3>
            <p class="text-gray-500 dark:text-gray-400 mb-4 animate-pulse">
                Espere unos segundos ...
            </p>
        </div>
    }
    else
    {
        <div class="px-6 py-8 space-y-6">
            <Card Class=@($"shadow-xl border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/90  {(IsSelectClosed ? "backdrop-blur-sm" : "")} z-40")>
                <CardHeader>
                    <CardTitle Class="flex items-center gap-2">
                        <User Class="h-5 w-5"/>
                        Información Personal
                    </CardTitle>
                </CardHeader>
                <CardContent>
                    <EditForm Model="updateUser" novalidate class="space-y-4 mt-4" OnValidSubmit=@SendEditUserProfile FormName="EditUserInfoForm">
                        <DataAnnotationsValidator/>


                            <div class="flex items-center gap-4 mb-6">
                                <div class="relative">
                                    <Avatar Class="w-20 h-20">
                                        @* TODO: Proximamente agregar a usuario una foto de perfil para que pueda poner su foto *@
                                        @if (!string.IsNullOrWhiteSpace(avatarUrl))
                                        {
                                            <AvatarImage Src="@avatarUrl" Alt="@User!.FullName"/>
                                        }
                                        else
                                        {
                                            <AvatarFallback Class=@($"{Gradient} text-white text-lg")>
                                                @GetInitials(User!.FullName)
                                            </AvatarFallback>
                                        }
                                    </Avatar>
                                </div>
                                <div class="flex-1">
                                    <h3 class="text-lg font-semibold">
                                        @User!.FullName
                                    </h3>
                                    <p class="text-gray-500 dark:text-gray-400  mb-2">
                                        @User!.Rol
                                    </p>
                                    <div class="flex gap-2">
                                        <Button
                                            Type="button"
                                            Variant="outline"
                                            Size="sm"
                                            Disabled
                                            Class="text-sm bg-transparent cursor-pointer disabled:cursor-not-allowed"
                                            OnClick="() => OpenFileExplorer()">
                                            <Camera Class="h-3 w-3 mr-1"/>
                                            Cambiar foto
                                        </Button>
                                        @if (!string.IsNullOrWhiteSpace(avatarUrl))
                                        {
                                            <Button
                                                Type="button"
                                                Variant="outline"
                                                Size="sm"
                                                Class="text-sm text-red-600 hover:text-red-700 hover:bg-red-50 bg-transparent cursor-pointer">
                                                <Trash2 Class="h-3 w-3 mr-1"/>
                                                Eliminar
                                            </Button>
                                        }
                                    </div>
                                    <input
                                        @ref="fileInput"
                                        type="file"
                                        accept="image/*"
                                        class="hidden"/>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="space-y-2">
                                    <Label For="fullName" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                        Nombre Completo
                                    </Label>
                                    <Input
                                        Type="text"
                                        @bind-Value="updateUser.FullName"
                                        Id="fullName"
                                        Name="fullName"
                                        Placeholder="Juan Perez"
                                        Autocomplete="off"
                                        Required
                                        Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"/>
                                    <ValidationMessage For="() => updateUser.FullName" class="text-xs text-red-600"/>
                                </div>

                                <div class="space-y-2">
                                    <Label For="email" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                        Email
                                    </Label>
                                    <Input
                                        Type="email"
                                        @bind-Value="updateUser.Email"
                                        Id="email"
                                        Name="email"
                                        Placeholder="juanperez@gmail.com"
                                        Autocomplete="off"
                                        Disabled
                                        Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"/>
                                    <ValidationMessage For="() => updateUser.Email" class="text-xs text-red-600"/>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="space-y-2">
                                    <Label For="areas" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                        Área
                                    </Label>
                                    <Select TItem="Areas"
                                            Items="@OptionsAreas"
                                            Id="areas"
                                            Value="AreaSeleccionada"
                                            ValueChanged="OnAreaSelectedChanged!"
                                            Placeholder="Selecciona el area al que perteneces"
                                            ItemTextSelector="x => x.ToString()"
                                            ClassButton=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400")
                                            ClassOption=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400")
                                            EnableSearch="false"
                                            HeightClass="max-h-[120px]"
                                            OnDropdownStateChanged="HandleDropdownState">
                                    </Select>
                                    <ValidationMessage For="() => updateUser.Area" class="text-xs text-red-600"/>
                                </div>

                                <div class="space-y-2">
                                    <Label For="role" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                        Rol
                                    </Label>
                                    <Input
                                        Type="text"
                                        Id="role"
                                        Name="role"
                                        @bind-Value="@User.Rol"
                                        Placeholder="Usuario"
                                        Autocomplete="off"
                                        Disabled
                                        Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"/>
                                </div>
                            </div>

                        <div class="flex justify-start gap-2 pt-4">
                            <Button Type="submit" Disabled="@(IsLoading)"
                                    Class=@($"{ColorService.GetButtonClassess()} text-white font-medium py-2.5 cursor-pointer")>

                                @if (IsLoading)
                                {
                                    <LoaderCircle Class="mr-3 size-5 animate-spin"/>
                                    <span>Guardando cambios...</span>
                                }
                                else
                                {
                                    <Save Class="me-2 size-5"/>
                                    <span>
                                        Guardar Cambios
                                    </span>
                                }
                            </Button>
                        </div>
                    </EditForm>
                </CardContent>
            </Card>


            <Card Class="shadow-xl border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/90  backdrop-blur-sm z-40">
                <CardHeader>
                    <CardTitle Class="flex items-center gap-2">
                        <Lock Class="h-5 w-5"/>
                        Cambiar Contraseña
                    </CardTitle>
                </CardHeader>
                <CardContent>
                    <EditForm Model="updatePassword" novalidate class="space-y-4 mt-4" OnValidSubmit=@SendEditUserPassword FormName="EditUserPasswordForm">
                        <DataAnnotationsValidator/>

                        <div class="space-y-2">
                            <Label For="password-hide" Id="password" Class="text-gray-700 dark:text-gray-300 mb-3 block">Contraseña Actual</Label>
                            <div class="relative">
                                <Input
                                    Type="@(showPassword ? "text" : "password")"
                                    @bind-Value="updatePassword.ActualPassword"
                                    Id="@(showPassword ? "password-show" : "password-hide")"
                                    Name="password"
                                    Placeholder="****************"
                                    Autocomplete="off"
                                    Required
                                    Class="pr-10 font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"/>

                                <ShowPassword @bind-IsVisible="showPassword"/>
                            </div>
                            <ValidationMessage For="() => updatePassword.ActualPassword" class="text-xs text-red-600"/>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-2">
                                <Label For="passwordNew-hide" Id="passwordNew" Class="text-gray-700 dark:text-gray-300 mb-3 block">Nueva Contraseña</Label>
                                <div class="relative">
                                    <Input
                                        Type="@(showPasswordNew ? "text" : "password")"
                                        @bind-Value="updatePassword.NewPassword"
                                        Id="@(showPasswordNew ? "passwordNew-show" : "passwordNew-hide")"
                                        Name="passwordNew"
                                        Placeholder="****************"
                                        Autocomplete="off"
                                        Required
                                        Disabled=@(updatePassword.ActualPassword == "")
                                        Class="pr-10 font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"/>

                                    <ShowPassword @bind-IsVisible="showPasswordNew"/>
                                </div>
                                <ValidationMessage For="() => updatePassword.NewPassword" class="text-xs text-red-600"/>
                            </div>
                            <div class="space-y-2">
                                <Label For="passwordConfirm-hide" Id="passwordConfirm" Class="text-gray-700 dark:text-gray-300 mb-3 block">Confirmar Contraseña</Label>
                                <div class="relative">
                                    <Input
                                        Type="@(showPasswordConfirm ? "text" : "password")"
                                        @bind-Value="updatePassword.ConfirmPassword"
                                        Id="@(showPasswordConfirm ? "passwordConfirm-show" : "passwordConfirm-hide")"
                                        Name="passwordConfirm"
                                        Placeholder="****************"
                                        Autocomplete="off"
                                        Required
                                        Disabled=@(updatePassword.ActualPassword == "")
                                        Class="pr-10 font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"/>

                                    <ShowPassword @bind-IsVisible="showPasswordConfirm"/>
                                </div>
                                <ValidationMessage For="() => updatePassword.ConfirmPassword" class="text-xs text-red-600"/>
                            </div>
                        </div>

                        <div class="flex justify-start gap-2 pt-4">
                            <Button Type="submit" Disabled="@(IsLoadingConfirm)"
                                    Class=@($"{ColorService.GetButtonClassess()} text-white font-medium py-2.5 cursor-pointer")>

                                @if (IsLoadingConfirm)
                                {
                                    <LoaderCircle Class="mr-3 size-5 animate-spin"/>
                                    <span>Cambiando contraseña...</span>
                                }
                                else
                                {
                                    <Lock Class="me-2 size-5"/>
                                    <span>
                                        Cambiar contraseña
                                    </span>
                                }
                            </Button>
                        </div>
                    </EditForm>
                </CardContent>
            </Card>

            <Card Class="shadow-xl border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/90  backdrop-blur-sm z-40">
                <CardHeader>
                    <CardTitle Class="flex items-center gap-2">
                        <Shield Class="h-5 w-5"/>
                        Autenticación de Dos Factores
