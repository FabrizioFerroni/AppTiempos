@using AppTiemposV3.SharedClases.Constants
@using AppTiemposV3.SharedClases.Enums
@using Microsoft.AspNetCore.Components.Authorization
@using static AppTiemposV3.SharedClases.Utilidades.DateHelpers
@using static AppTiemposV3.Web.Utils.Helpers;

@* Modal show requeriment *@
<Modal Method="show" IdElement="Id" Id=@($"dialog-modal-show-req-{IdModalStr}") Class="select-none">
    <div class="px-6 my-4">
        <div class="flex justify-between items-center gap-3 mt-[-0.5rem]">
            <div class="flex gap-2 items-center">
                <FileText Class="w-5 h-5 text-blue-600" />
                <span class="text-gray-700 dark:text-gray-300 text-md">
                    Detalles del Requerimiento
                </span>
            </div>
            <Button
                Variant="ghost"
                Size="sm"
                Command="close"
                CommandFor=@($"show-{Id}")
                Class="text-xs cursor-pointer">
                <Close Class="dark:text-gray-300 text-gray-600 h-4 w-4"/>
            </Button>
        </div>

        @if (IsLoadingData)
        {
            <div class="flex flex-col items-center justify-center py-12 text-center">
                <LoaderCircle Class="w-16 h-16 mb-4 animate-spin text-gray-900 dark:text-gray-100"/>
                <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">
                    Cargando datos del requerimiento
                </h3>
                <p class="text-gray-500 dark:text-gray-400 mb-4 animate-pulse">
                    Espere unos segundos ...
                </p>
            </div>
        }
        else
        {
            <div class="space-y-4">
                <div class="grid grid-cols-2 gap-4 mt-2">
                    <div class="flex flex-col">
                        <label class="text-sm font-medium text-gray-600 dark:text-gray-300">
                            ID del Requerimiento
                        </label>
                        @{
                            string reqId = $"ReqID{requerimentShow.ReqID}";
                        }
                        <p class="text-lg font-semibold text-blue-600 flex items-center justify-between">
                            @reqId
                            <Button
                                Variant="ghost"
                                Size="sm"
                                Class="cursor-pointer text-gray-600 dark:text-gray-300"
                                OnClick="@(() => CopyToClipboard(reqId, "ReqID", "reqId"))">
                                <ClipboardCopy Class="h-4 w-4"/>
                            </Button>
                        </p>
                        @if (mensajes.ContainsKey("reqId"))
                        {
                            (string texto, bool exito) = mensajes["reqId"];
                            <span class="text-xs @(exito ? "text-green-600" : "text-red-600")">
                                @texto
                            </span>
                        }
                    </div>

                    <div class="flex flex-col">
                        <label class="text-sm font-medium text-gray-600 dark:text-gray-300">
                            Tipo de requerimiento
                        </label>
                        <p class="text-lg font-semibold text-gray-600 dark:text-gray-300">
                            @requerimentShow.Category.Name
                        </p>
                    </div>
                </div>
                <div class="grid grid-cols-3 gap-4">
                    <div class="flex flex-col">
                        <label class="text-sm font-medium text-gray-600 dark:text-gray-100 ">
                            Estado
                        </label>
                        <p class="text-lg font-semibold text-gray-600 dark:text-gray-100">
                            @($"{requerimentShow.Estado}")
                        </p>
                    </div>
                    
                    <div class="flex flex-col">
                        <label class="text-sm font-medium text-gray-600 dark:text-gray-100 ">
                            Etapa General
                        </label>
                        <p class="text-lg font-semibold text-gray-600 dark:text-gray-100">
                            @($"{requerimentShow.EtapaActual}")
                        </p>
                    </div>

                    <div class="flex flex-col">
                        <label class="text-sm font-medium text-gray-600 dark:text-gray-100 ">
                            Etapa (Ult. Actividad)
                        </label>
                        <p class="text-lg font-semibold text-gray-600 dark:text-gray-100">
                            @($"{requerimentShow.Etapa}")
                        </p>
                    </div>
                </div>

                <div>
                    <label class="text-sm font-medium text-gray-900 dark:text-gray-100 ">
                        Titulo
                    </label>
                    <p class="text-lg font-semibold text-gray-900 dark:text-gray-100">
                        @($"{requerimentShow.Titulo}")
                    </p>
                </div>

                <div>
                    <label class="text-sm font-medium text-gray-900 dark:text-gray-100 ">
                        Cliente
                    </label>
                    <p class="text-lg font-semibold text-gray-900 dark:text-gray-100">
                        @($"{requerimentShow.Cliente}")
                    </p>
                </div>

                <div>
                    <label class="text-sm font-medium text-gray-900 dark:text-gray-100">
                        Detalle
                    </label>
                    <p class="text-sm text-gray-600 dark:text-gray-300 bg-gray-50 dark:bg-gray-700 p-3 rounded-lg mt-1">
                        @requerimentShow.Descripcion
                    </p>
                </div>

                <div>
                    <label class="text-sm font-medium text-gray-900 dark:text-gray-100">
                        Enlace al Ticket
                    </label>
                    <Button
                        Variant="outline"
                        Size="sm"
                        Class="w-full justify-start mt-1 text-gray-600 dark:text-gray-300 cursor-pointer"
                        OnClick="() => {  OpenCrmUrl(requerimentShow.Url!);}"
                    >
                        <ExternalLink Class="w-4 h-4 mr-2" />
                        Abrir en el CRM
                    </Button>
                </div>

                @if (requerimentShow.StoryPoint != "0.00")
                {
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col">
                            <label class="text-sm font-medium text-gray-600 dark:text-gray-300">
                                Tiempo Estimado
                            </label>
                            <p class="text-lg font-semibold text-gray-600 dark:text-gray-300">
                                <AuthorizeView>
                                    @{
                                        //string area = @context.User.Claims.FirstOrDefault(c => c.Type == CustomClaimTypes.Area)!.Value;
                                        Areas area = Enum.Parse<Areas>(@context.User.Claims.FirstOrDefault(c => c.Type == CustomClaimTypes.Area)!.Value!, ignoreCase: true);
                                    }
                                    @ObtainTimeEstimated(requerimentShow.StoryPoint, area)
                                </AuthorizeView>
                            </p>
                        </div>

                        <div class="flex flex-col">
                            <label class="text-sm font-medium text-gray-600 dark:text-gray-300">
                                Tiempo Real
                            </label>
                            <p class="text-lg font-semibold text-gray-600 dark:text-gray-300">
                                @FormatTime(requerimentShow.WorkedTime)
                            </p>
                        </div>
                    </div>
                }

                @if (!String.IsNullOrWhiteSpace(requerimentShow.ConjuntoCambios))
                {
                    <div>
                        <label class="text-sm font-medium text-gray-900 dark:text-gray-100">
                            Conjunto de Cambios
                        </label>
                        <p id="conjuntoCambios" class="text-sm text-gray-600 dark:text-gray-300 bg-gray-50 dark:bg-gray-700 p-3 rounded-lg mt-1 flex items-center justify-between">
                            <span>
                                @requerimentShow.ConjuntoCambios
                            </span>
                            <Button
                                Variant="ghost"
                                Size="sm"
                                Class="cursor-pointer"
                                OnClick="@(() => CopyToClipboard(requerimentShow.ConjuntoCambios, "Conjuntos de cambios", "conjuntoCambios"))"
                            >
                                <ClipboardCopy Class="h-4 w-4" />
                            </Button>
                        </p>

                        @if (mensajes.ContainsKey("conjuntoCambios"))
                        {
                            (string texto,bool exito) = mensajes["conjuntoCambios"];
                            <span class="text-xs @(exito ? "text-green-600" : "text-red-600")">
                                @texto
                            </span>
                        }
                    </div>
                }

                <div>
                    @* TODO: Ver esto despues *@
                    <label class="text-sm font-medium text-gray-600 dark:text-gray-300">
                        Estado de Rechazos
                    </label>
                    <div class="flex items-center justify-between mt-1">
                        <div class="flex items-center gap-2">
                            @if (requerimentShow.TotalRejections == 0)
                            {
                                <CheckCircle class="w-4 h-4 text-green-500"/>
                                <span class="text-sm text-gray-600 dark:text-gray-300">
                                    Sin rechazos
                                </span>
                            }
                            else
                            {
                                <XCircle class="w-4 h-4 text-red-500" /> 
                                <span class="text-sm text-gray-600 dark:text-gray-300">
                                    Tiene rechazos
                                </span>
                            }
                        </div>
                        <div class="text-right">
                            <span class="text-lg font-semibold text-gray-600 dark:text-gray-300">
                                @requerimentShow.TotalRejections
                            </span>
                            <p class="text-xs text-gray-600 dark:text-gray-300">
                                @Plural(requerimentShow.TotalRejections, "rechazo","rechazos")
                            </p>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="text-sm font-medium text-gray-600 dark:text-gray-300">
                        Documentos del requerimiento
                    </label>
                    <div class="flex items-center justify-between mt-1">
                        <div class="flex items-center gap-2">
                            @if (documentsFiles == 0)
                            {
                                <Files class="w-4 h-4 text-gray-600 dark:text-gray-300"/>
                                <span class="text-sm text-gray-600 dark:text-gray-300">
                                    No tiene documentos subidos
                                </span>
                            }
                            else
                            {
                                <Files class="w-4 h-4 text-gray-600 dark:text-gray-300" />
                                <span class="text-sm text-gray-600 dark:text-gray-300">
                                    @($"Tiene {documentsFiles} documentos subidos")
                                </span>
                            }
                        </div>
                        <div class="text-right">
                            <Button
                                Variant="outline"
                                Size="sm"
                                Id=@($"documents-{requerimentShow.Id}")
                                OnClick="@(() => {  })"
                                Class="text-gray-400  dark:text-gray-300 dark:border-gray-500 dark:bg-gray-600  dark:hover:bg-orange-800/20 dark:hover:border-orange-900/50 cursor-pointer">
                                <FolderOpen Class="w-4 h-4"/>
                            </Button>
                        </div>
                    </div>
                </div>
                

                <div>
                    <label class="text-sm font-medium text-gray-900 dark:text-gray-100">
                        Nombre para la carpeta
                    </label>
                    <p id="folderPath" class="text-sm text-gray-600 dark:text-gray-300 bg-gray-50 dark:bg-gray-700 p-3 rounded-lg mt-1 flex items-center justify-between">
                        <span>
                            @requerimentShow.FolderPath
                        </span>
                        <Button
                            Variant="ghost"
                            Size="sm"
                            Class="cursor-pointer"
                            OnClick="@(() => CopyToClipboard(requerimentShow.FolderPath!, "Nombre de carpeta", "folderPath"))"
                        >
                            <ClipboardCopy Class="h-4 w-4" />
                        </Button>
                    </p>

                    @if (mensajes.ContainsKey("folderPath"))
                    {
                        var (texto, exito) = mensajes["folderPath"];
                        <span class="text-xs @(exito ? "text-green-600" : "text-red-600")">
                            @texto
                        </span>
                    }
                </div>

            </div>
            <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400 mt-4">
                <span class="flex items-center">
                    Requerimiento dado de alta el: @FormatDateAndTime(requerimentShow.CreatedAt)
                </span>
                @if (requerimentShow.ModifiedAt is not null && FormatDateAndTime(requerimentShow.ModifiedAt) != FormatDateAndTime(requerimentShow.CreatedAt))
                {
                    <span class="flex items-center">
                        y
                    </span>
                    <span class="flex items-center">
                        actualizado el: @FormatDateAndTime(requerimentShow.ModifiedAt)
                    </span>
                }
            </div>
        }
    </div>
</Modal>
@* Fin Modal show requeriment *@

<button type="button" @ref="showModalRef" class="hidden" id=@($"showModalShow-{Id}") command="show-modal" commandfor=@($"show-{Id}")></button>      
<button type="button" @ref="closeModalRef" class="hidden" id=@($"closeModalShow-{Id}") command="close" commandfor="@($"show-{Id}")"></button>      
