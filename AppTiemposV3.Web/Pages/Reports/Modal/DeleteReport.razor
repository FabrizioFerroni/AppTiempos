<DeleteModal IdElement="@Id"
             Id=@($"dialog-delete-{Id}")
             Title="Deseas eliminar el reporte"
             Subtitle=@($"¿Estas seguro que deseas eliminar el reporte {Name}?")
             OnConfirm="async (id) => await DeleteReportAc(id)" />


<Modal Method="deleteLoading" IdElement="IdShow" Id=@($"dialog-modal-delete-loading-req-{IdModalStr}")>
    <div class="flex flex-col items-center justify-center py-12 text-center">
        <LoaderCircle Class="w-16 h-16 mb-4 animate-spin text-gray-900 dark:text-gray-100" />
        <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">
            Eliminando reporte @Name
        </h3>
        <p class="text-gray-500 dark:text-gray-400 mb-4 animate-pulse">
            Espere unos segundos ...
        </p>
    </div>
</Modal>

<button type="button" @ref="showModalRef" class="hidden" id=@($"showModalLoad-{Id}") command="show-modal" commandfor=@($"deleteLoading-{IdShow}")></button>
<button type="button" @ref="showModalRef2" class="hidden" id=@($"showModalLDelete-{Id}") command="show-modal" commandfor=@($"delete-{Id}")></button>
<button type="button" @ref="closeModalRef" class="hidden" id=@($"closeModalLoad-{Id}") command="close" commandfor="@($"deleteLoading-{IdShow}")"></button>      