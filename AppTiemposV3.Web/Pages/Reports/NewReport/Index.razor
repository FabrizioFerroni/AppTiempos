                                                                } else if(FrecuenciaSeleccionadaCustom == "Semanal (Lunes)")
                                                                {
                                                                    <span>Se enviará todos los lunes a las 8:00 AM</span>
                                                                }
                                                                else if (FrecuenciaSeleccionadaCustom == "Mensual (Día 1)")
                                                                {
                                                                    <span>Se enviará el día 1 de cada mes a las 8:00 AM</span>
                                                                }
                                                            </p>
                                                        </div>
                                                        <div class="space-y-2">
                                                            <Label For="destinatario" Id="destinatarioLabel">Destinatarios</Label>
                                                            <div class="space-y-2">
                                                                @for (int i = 0; i < RecipientsCustom.Count; i++)
                                                                {
                                                                    int idxC = i;

                                                                    <div class="flex items-center gap-2">
                                                                        <Input Type="email"
                                                                               Placeholder="correo@ejemplo.com"
                                                                               Value="@RecipientsCustom[idxC]"
                                                                               ValueChanged="@((string? v) => OnRecipientChangedCustom(idxC, v))"
                                                                               Autocomplete="off"
                                                                               Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 mt-2" />
                                                                        <Button Variant="outline" Size="sm" Class="cursor-pointer" OnClick="@(() => RemoveRecipientCustom(idxC))">
                                                                            <Close Class="w-4 h-4" />                                                                   
                                                                        </Button>
                                                                    </div>
                                                                }
                                                            <Button Variant="outline" Size="sm" Class="cursor-pointer" OnClick="AddRecipientCustom">
                                                                    <Plus Class="w-4 h-4 mr-2" />
                                                                    Agregar Destinatario
                                                                </Button>
                                                            </div>
                                                            <p class="text-sm text-gray-600 dark:text-gray-300">
                                                                Los reportes se enviarán por email a estos destinatarios automáticamente
                                                            </p>
                                                        </div>
                                                        <div class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg mt-2">
                                                            <div class="flex items-start gap-3">
                                                                <AlertCircle Class="w-5 h-5 text-blue-600 dark:text-blue-400 mt-0.5" />
                                                                <div class="space-y-1">
                                                                    <p class="text-sm font-medium text-blue-900 dark:text-blue-100">
                                                                        Información sobre Programación
                                                                    </p>
                                                                    <p class="text-sm text-blue-700 dark:text-blue-300">
                                                                        Los reportes programados se ejecutarán automáticamente y se enviarán por email en formato
                                                                        PDF. Asegúrate de que las direcciones de correo sean válidas.
                                                                    </p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </CardContent>
                                        </Card>
                                    </TabsContent>                                
                                </Tabs>
                            }
                        </div>
                </CardContent>
            </Card>
        </div>
    </article>
</div>


@code {
    RenderFragment RenderJoinNode(JoinDefinition join, int level) => __builder =>
    {
        int padding = level * 20;

        <div class="flex flex-col gap-2 p-3 border border-gray-200 dark:border-gray-600 bg-white/80 dark:bg-gray-700 rounded-lg shadow-sm"
             style="margin-left: @(padding)px">

            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <Link class="w-4 h-4 text-blue-600" />
                    <div>
                        <p class="font-medium">@NameToSpanish(join.Nombre)</p>
                        <p class="text-xs text-muted-foreground">
                            @InnerOrLeftCardinal(join.JoinType, join.Nombre, join.Table, join.ParentTable, string.Empty, join.Field, join.TargetField)
                        </p>
                    </div>
                </div>
                <div class="flex gap-2">
                    <Button Variant="ghost" Size="sm" OnClick="@(() => ToggleRelacionadaDetails(join.Table))" Class="cursor-pointer">
                        @if (ExpandedRelacionadasTables.Contains(join.Table))
                        {
                            <ChevronUp Class="w-4 h-4" />
                        }
                        else
                        {

                            <ChevronDown Class="w-4 h-4" />
                        }
                    </Button>
                    <Button Variant="ghost" Size="sm" Class="text-red-600 cursor-pointer" OnClick="@(() => RemoveJoin(join.Table))">
                        <Trash2 class="w-4 h-4" />
                    </Button>
                </div>
            </div>

            @if (ExpandedRelacionadasTables.Contains(join.Table))
            {
                <div class="p-3 bg-gray-50 dark:bg-gray-800/50 rounded-md grid grid-cols-2 gap-3 text-xs">
                    @foreach (TableField? campo in GetFields(join.Table))
                    {
                        SelectedField key = new SelectedField(_tableMap[join.Table.ToString()], campo.Value);
                        bool isChecked = _selectedFields.ContainsKey(key);
                        <div class="flex gap-2 items-center">
                            <Checkbox 
                                Value="@isChecked" 
                                ValueChanged="v => OnFieldToggle(key, v)" 
                                Label="@campo.Value" 
                                Style=@($"--radio-checked-color: {GetHexColorGradient(ColorService.GetCurrentColor().Gradient)};") 
                                />
                            <Input 
                                Placeholder="Alias" 
                                Disabled="!isChecked" 
                                Value="@(isChecked? _selectedFields[key] : "")" 
                                ValueChanged="v => OnAliasChanged(key, v)" 
                                Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                                Style="height: calc(var(--spacing) * 8) !important;" 
                                />
                        </div>
                    }
                </div>
            }

            @{
                IEnumerable<JoinDefinition> subRel = GetAvailableJoinsRelaciones(join.Table);
                if(subRel.Any()){
                    <div class="mt-2 pt-2 border-t border-gray-100 dark:border-gray-600">
                        <p class="text-[10px] uppercase font-bold text-gray-400 mb-1">Relacionar con @NameToSpanish(join.Nombre)</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (JoinDefinition subJoin in GetAvailableOptionsFor(join.Table, true))
                            {
                                <Button Variant="outline" Size="xs" OnClick="@(() => AddJoinRel(subJoin, join.Table))" Class="cursor-pointer">
                                    <Plus class="w-3 h-3 mr-1" /> @NameToSpanish(subJoin.Nombre)
                                </Button>
                            }
                        </div>
                    </div>
                }
            }            

            @{
                IEnumerable<JoinDefinition> children = GetChildJoins(join.Table);
                if (children.Any())
                {
                    <div class="mt-3 space-y-3 border-l-2 border-blue-500/30 pl-4">
                        @foreach (JoinDefinition child in children)
                        {
                            @RenderJoinNode(child, 0)
                        }
                    </div>
                }
            }
        </div>
    };
}