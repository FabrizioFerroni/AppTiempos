@page "/app/reportes/nuevo"
@using static AppTiemposV3.Web.Utils.ReportMetadata
@using AppTiemposV3.Web.Utils

<PageTitle>
    Nuevo Reporte | TimeTracker Pro
</PageTitle>

<div class="flex flex-col w-full">
    <Navbar Title="Nuevo Reporte" Subtitle="Constructor de reportes personalizados" OnToggleSidebar="HandleSidebarToggle">
        <div class="text-right">
            <Enlace Href="/app/reportes" Target="_self" Class="border border-gray-300  dark:hover:bg-gray-700 h-9 px-3 text-sm inline-flex items-center justify-center rounded-md font-medium transition-colors focus:outline-none focus:ring-0 focus:ring-offset-0 disabled:opacity-50 disabled:pointer-events-none text-gray-400  dark:text-gray-300 dark:border-gray-500 cursor-pointer">
                <ArrowLeft Class="h-4 w-4 mr-2" />
                Volver
            </Enlace>
        </div>
    </Navbar>
    <article class="content px-4">
        <div class="px-6 space-y-6 mt-6">
            <Card Class=@($"shadow-xl border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/90")>
                <CardHeader>
                    <div class="flex justify-between items-center">
                        <div class="flex flex-col gap-1">
                            <h2 class="text-2xl font-bold">
                                Nuevo reporte
                            </h2>
                            <p class="text-[hsl(var(--muted-foreground))]">
                                Crea tus reportes personalizados
                            </p>
                        </div>
                    </div>
                </CardHeader>
                <CardContent>
                        <div class="space-y-6 select-none">
                            <Card Class=@($"shadow-xl border-gray-200 dark:border-gray-600 bg-white/80 dark:bg-gray-800/90 hover:shadow-md transition-shadow {(IsSelectClosed ? "backdrop-blur-sm" : "")}")>
                                 <EditForm Enhance Model=@createNewReport class="space-y-4 mt-2" novalidate OnValidSubmit=@SendCreateNewReport FormName="CreateReportForm">
                                    <DataAnnotationsValidator/>
                                    <CardHeader>
                                        <div class="flex items-center justify-between">
                                            <div>
                                                <CardTitle>
                                                    Constructor de Reportes
                                                </CardTitle>
                                                <p class="text-sm text-[hsl(var(--muted-foreground))] mt-1">
                                                    Crea reportes con datos relacionados de múltiples tablas
                                                </p>
                                            </div>
                                            <div class="flex gap-2">
                                            <Button Variant="outline"
                                                    Type="submit"
                                                    Size="sm"
                                                    Class="@ColorService.GetButtonClassess()"
                                                    Disabled="@(IsSendingReport || (string.IsNullOrWhiteSpace(createNewReport.Name) || string.IsNullOrWhiteSpace(createNewReport.Description)))">
                                                    @if (IsSendingReport)
                                                    {
                                                        <LoaderCircle Class="mr-3 size-5 animate-spin" />
                                                        <span>Guardando...</span>
                                                    }
                                                    else{
                                                        <Save Class="w-4 h-4 mr-2" />
                                                        <span>Guardar</span>
                                                    }
                                                </Button>
                                                <Button Variant="outline" Size="sm" Disabled>
                                                    <Eye Class="w-4 h-4 mr-2" />
                                                    Vista Previa
                                                </Button>
                                            </div>
                                        </div>
                                    </CardHeader>
                                    <CardContent Class="space-y-4">
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                            <div>
                                                <Label For="reportName" Id="reportNameLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                                    Nombre del Reporte
                                                </Label>
                                                <Input
                                                    Type="text"
                                                    Id="reportName"
                                                    Name="reportName"
                                                    @bind-Value="@createNewReport.Name"
                                                    Placeholder="Reporte de Actividades por Cliente"
                                                    Autocomplete="off"
                                                    Required
                                                    Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                                                />
                                            </div>
                                             <div>
                                                <Label For="baseTable" Id="baseTableLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                                    Tabla Base
                                                </Label>
                                                <Select TItem="string"
                                                        Items="@OptionsBasesDatos"
                                                        Id="baseTable"
                                                        Value="@BasesDatosSeleccionado"
                                                        Disabled=@(_reportMode == "custom")
                                                        ValueChanged="OnBasesDatosSelectedChanged!"
                                                        Placeholder="Selecciona la base de datos principal"
                                                        ItemTextSelector="x => x"
                                                        ClassButton=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500")
                                                        ClassOption=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500")
                                                
                                                        OnDropdownStateChanged="HandleDropdownState">
                                                </Select>
                                                @* HeightClass="max-h-[70px]" *@
                                            </div>
                                        </div>
                                        <div>
                                            <Label For="description" Id="descriptionLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                                Descripción
                                            </Label>
                                            <TextArea Id="description"
                                                      Placeholder="Describe el propósito de este reporte..."
                                                      Required
                                                      @bind-Value="@createNewReport.Description"
                                                      Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                                                      Rows="3">
                                            </TextArea>
                                        </div>
                                        <div>
                                            <Label Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                                Modo de Construcción
                                            </Label>
                                            <div class="flex gap-4 mt-2">
                                                <div class="flex items-center space-x-2">                                           
                                                    @{
                                                        string selectedMethod = "visual";
                                                    }
                                                    <Radius Id="visual"
                                                            Name="reportName"
                                                            Class=@($"cursor-pointer")
                                                            Label="Constructor Visual"
                                                            Value
                                                            OnClick="() => { HandleModeConstruction(selectedMethod); }"
                                                            Style=@($"--radio-checked-color: {GetHexColorGradient(ColorService.GetCurrentColor().Gradient)};") />
                                                </div>
                                                <div class="flex items-center space-x-2">
                                                    @{
                                                        string selectedMethod2 = "custom";
                                                    }
                                                    <Radius Id="custom"
                                                            Name="reportName"
                                                            Class="cursor-pointer"
                                                            Label="SQL Personalizado"
                                                            OnClick="() => { HandleModeConstruction(selectedMethod2); }"
                                                            Style=@($"--radio-checked-color: {GetHexColorGradient(ColorService.GetCurrentColor().Gradient)};") />
                                                </div>
                                            </div>

                                        </div>
                                    </CardContent>
                                </EditForm>
                            </Card>

                            @if (!string.IsNullOrWhiteSpace(_reportMode) && _reportMode == "visual")
                            {
                            
                                <Tabs Value="@tab" Class="space-y-4 " ValueChanged="v => tab = v">
                                    <TabsList Class="grid w-full grid-cols-6 shadow-xl border-gray-200 dark:border-gray-600 bg-white/80 dark:bg-gray-700 hover:shadow-md transition-shadow px-2">
                                        <TabsTrigger ActiveClass="bg-white/80 dark:bg-gray-900" Value="joins" OnClick="@RebuildQuery">Relaciones</TabsTrigger>
                                        <TabsTrigger ActiveClass="bg-white/80 dark:bg-gray-900"  Value="filters">Filtros</TabsTrigger>
                                        <TabsTrigger ActiveClass="bg-white/80 dark:bg-gray-900"  Value="metrics">Métricas</TabsTrigger>
                                        <TabsTrigger ActiveClass="bg-white/80 dark:bg-gray-900"  Value="grouping">Agrupación</TabsTrigger>
                                        <TabsTrigger ActiveClass="bg-white/80 dark:bg-gray-900"  Value="schedule">Programación</TabsTrigger>
                                        <TabsTrigger ActiveClass="bg-white/80 dark:bg-gray-900"  Value="sql">SQL</TabsTrigger>
                                    </TabsList>

                                    <TabsContent Value="joins">
                                        <Card Class=@($"shadow-xl border-gray-200 dark:border-gray-600 bg-white/80 dark:bg-gray-800/90 hover:shadow-md transition-shadow {(IsSelectClosed ? "backdrop-blur-sm" : "")}")>
                                          <CardHeader>
                                            <CardTitle Class="flex items-center gap-2">
                                              <Link Class="w-5 h-5" />
                                              Tablas Relacionadas
                                            </CardTitle>
                                                <p class="text-sm text-[hsl(var(--muted-foreground))]">
                                              Selecciona las tablas relacionadas para incluir sus datos en el reporte
                                            </p>
                                          </CardHeader>
                                          <CardContent Class="space-y-4">
                                            <div class="flex justify-between items-center gap-2">
                                                <div class="text-left">
                                                    @if (!string.IsNullOrWhiteSpace(BasesDatosSeleccionado))
                                                    {
                                                        <Label>Tabla Base: <strong>@BasesDatosSeleccionado</strong></Label>
                                                        <p class="text-sm text-[hsl(var(--muted-foreground))] mt-1">
                                                            Esta es la tabla principal del reporte. Puedes agregar tablas relacionadas abajo.
                                                        </p>
                                                    }
                                                    else
                                                    {
                                                        <Label>Tabla Base: No hay base de datos seleccionada</Label>
                                                        <p class="text-sm text-[hsl(var(--muted-foreground))] mt-1">
                                                            En el card de arriba donde dice Tabla base elija una tabla por donde salir
                                                        </p>
                                                    }
                                                </div>

                                                <Button Variant="ghost"
                                                        Size="sm"
                                                        Class="p-1 cursor-pointer"
                                                        OnClick="@(() => TogglePrincipalDetails(BasesDatosSeleccionado!))"
                                                        Disabled=string.IsNullOrWhiteSpace(BasesDatosSeleccionado!)
                                                >
                                                    @if (ExpandedPrincipalTables.Contains(BasesDatosSeleccionado!))
                                                    {
                                                        <ChevronUp Class="w-4 h-4" />
                                                    }
                                                    else
                                                    {
                                                        <ChevronDown Class="w-4 h-4" />
                                                    }
                                                </Button>
                                            </div>
                                                @if (ExpandedPrincipalTables.Contains(BasesDatosSeleccionado!) && !string.IsNullOrWhiteSpace(BasesDatosSeleccionado!))
                                                {
                                                    <div class="p-3 space-y-3">
                                                        <div class="grid grid-cols-2 gap-3 text-xs">
                                                            @foreach (TableField? campo in GetFields(GetTableRelations(BasesDatosSeleccionado!)))
                                                            {
                                                                SelectedField key = new SelectedField(_tableMap[BasesDatosSeleccionado!], campo.Value);
                                                                bool isChecked = _selectedFields.ContainsKey(key);
                                                                string? alias = isChecked ? _selectedFields[key] : string.Empty;
                                                                <div @key="key" class="flex gap-2 items-center justify-start">
                                                                    <Checkbox Id="@campo.Value"
                                                                              Name="@campo.Value"
                                                                              Class="cursor-pointer"
                                                                              Label="@campo.Value"
                                                                              Value="@isChecked"
                                                                              ValueChanged="v => OnFieldToggle(key, v)"
                                                                              Style=@($"--radio-checked-color: {GetHexColorGradient(ColorService.GetCurrentColor().Gradient)};") />

                                                                    <Input Type="text"
                                                                           Id=@($"text-bs-{campo.Value}")
                                                                           Name=@($"text-bs-{campo.Value}")
                                                                           Placeholder="Nombre de columna"
                                                                           Autocomplete="off"
                                                                           Disabled=@(!isChecked)
                                                                           Value="@alias"
                                                                           ValueChanged="v => OnAliasChanged(key, v)"
                                                                           Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                                                                           Style="height: calc(var(--spacing) * 8) !important;" />
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                            <div class="space-y-2">
                                              <Label>Tablas Relacionadas Activas</Label>
                                                @if (!GetRootJoins().Any())
                                                 {
                                                    <p class="text-sm text-[hsl(var(--muted-foreground))]">
                                                        No hay tablas relacionadas agregadas
                                                    </p>
                                                 }
                                                <div class="space-y-2 mt-2">
                                                    @foreach (JoinDefinition? join in ActiveJoins.Where(j => j.ParentTable == _tableMap[BasesDatosSeleccionado!]))
                                                    {
                                                        @RenderJoinNode(join, 0)
                                                    }
                                                </div>
                                          
                                            </div>

                                            <div class="space-y-2">
                                              <Label>Agregar Tabla Relacionada</Label>
                                                @if (string.IsNullOrWhiteSpace(BasesDatosSeleccionado))
                                                {
                                                    <p class="text-sm text-[hsl(var(--muted-foreground))]">
                                                        Seleccione una tabla para relacionar
                                                    </p>
                                                }
                                                    else if (!GetAvailableOptionsFor(GetTableRelations(BasesDatosSeleccionado!), false).Any())
                                                {
                                                    <p class="text-sm text-[hsl(var(--muted-foreground))]">
                                                        No hay más tablas disponibles para relacionar
                                                    </p>
                                                }
                                                else
                                                {
                                                    <div class="flex flex-wrap gap-2 mt-2"> 
                                                        @foreach (JoinDefinition available in GetAvailableOptionsFor(GetTableRelations(BasesDatosSeleccionado!), false))
                                                        {
                                                            <Button 
                                                                Variant="outline"
                                                                Size="sm"
                                                                Class="cursor-pointer"
                                                                OnClick="@(() => AddJoin(available))"
                                                            >
                                                                <Plus Class="w-4 h-4 mr-2" />
                                                                @NameToSpanish(available.Nombre)
                                                            </Button>
                                                        }
                                                    </div>                                                    
                                                }                                            
                                            </div>
                                          </CardContent>
                                        </Card>
                                      </TabsContent>

                                    <TabsContent Value="filters">
                                        <Card Class=@($"shadow-xl border-gray-200 dark:border-gray-600 bg-white/80 dark:bg-gray-800/90 hover:shadow-md transition-shadow {(IsSelectClosed ? "backdrop-blur-sm" : "")}")>
                                            <CardHeader> 
                                                <div class="flex items-center justify-between">
                                                    <div>
                                                        <CardTitle Class="flex items-center gap-2">
                                                            <Filter Class="w-5 h-5" />
                                                            Filtros
                                                        </CardTitle>
                                                        <p class="text-sm text-[hsl(var(--muted-foreground))]">
                                                            Selecciona los campos por los cuales quieras filtrar los datos
                                                        </p>
                                                    </div>
                                                    <Button Variant="outline"
                                                                Size="sm"
                                                                Class="cursor-pointer"
                                                            Disabled=@string.IsNullOrWhiteSpace(BasesDatosSeleccionado!)
                                                            OnClick="() => AddFilter()">
                                                        <Plus Class="w-4 h-4 mr-2" />
                                                        Agregar Filtro
                                                    </Button>
                                                </div>
                                            </CardHeader>
                                            <CardContent Class="space-y-4">
                                                @if(Filters.Count == 0)
                                                {
                                                    <div class="text-center py-8 text-[hsl(var(--muted-foreground))]">
                                                        <Filter Class="w-12 h-12 mx-auto mb-4 opacity-50" />
                                                        <p>No hay filtros personalizados configurados</p>
                                                     </div>   
                                                } else {
                                                    @foreach ((ReportFilter filter, int index) in Filters.Select((ReportFilter filter, int index) => (filter, index)))
                                                    {
                                                        <div @key="filter.Id">
                                                            <Card Class=@($"shadow-xl border-gray-200 dark:border-gray-600 bg-white/80 dark:bg-gray-800/90 hover:shadow-md transition-shadow p-4 flex items-center gap-4") Id=@($"filter-{index + 1}")>
                                                                <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center">
                                                                    <span class="text-sm font-medium text-blue-600 dark:text-blue-400">
                                                                        @(index + 1)
                                                                    </span>
                                                                </div>
                                                                <div class="grid grid-cols-1 md:grid-cols-5 gap-4 items-end flex-1">
                                                                    <div class="flex flex-col gap-2">
                                                                        <Label For=@($"baseTableFilter-{index + 1}")>
                                                                            Tabla
                                                                        </Label>
                                                                        <Select TItem="string"
                                                                                Items="@OptionsBasesDatosFilter"
                                                                                Id=@($"baseTableFilter-{index + 1}")
                                                                                Value="@filter.Tabla"
                                                                                ValueChanged="v => OnBasesDatosFilterSelectedChanged(filter, v)!"
                                                                                Placeholder="Selecciona la base de datos"
                                                                                ItemTextSelector="x => x"
                                                                                Disabled=@string.IsNullOrWhiteSpace(BasesDatosSeleccionado!)
                                                                                ClassButton=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500")
                                                                                ClassOption=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500")
                                                                                StyleButton="height: calc(var(--spacing) * 8) !important;"
                                                                                OnDropdownStateChanged="HandleDropdownState">
                                                                        </Select>
                                                                    </div>
                                                                    <div class="flex flex-col gap-2">
                                                                        <Label For=@($"optionsCampos-{index + 1}")>
                                                                            Campo
                                                                        </Label>
                                                                        <Select TItem="string"
                                                                                Items="@filter.OptionsCampos"
                                                                                Id=@($"optionsCampos-{index + 1}")
                                                                                Value="@filter.Campo"
                                                                                Disabled=@string.IsNullOrWhiteSpace(filter.Tabla)
                                                                                ValueChanged="v => filter.Campo = v"
                                                                                Placeholder="Selecciona el campo de la tabla que desea filtrar"
                                                                                ItemTextSelector="x => x"
                                                                                ClassButton=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500")
                                                                                ClassOption=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500")
                                                                                StyleButton="height: calc(var(--spacing) * 8) !important;"
                                                                                OnDropdownStateChanged="HandleDropdownState">
                                                                        </Select>
                                                                    </div>
                                                                    <div class="flex flex-col gap-2">
                                                                        <Label For=@($"operadorFilter-{index + 1}")>
                                                                            Operador
                                                                        </Label>
                                                                        <Select TItem="string"
                                                                                Items="@OptionsOperador"
                                                                                Id=@($"operadorFilter-{index + 1}")
                                                                                Value="@filter.Operador"
                                                                                ValueChanged="v => filter.Operador = v"
                                                                                ItemTextSelector="x => x"
                                                                                ClassButton=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500")
                                                                                ClassOption=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500")
                                                                                StyleButton="height: calc(var(--spacing) * 8) !important;"
                                                                                OnDropdownStateChanged="HandleDropdownState">
                                                                        </Select>
                                                                    </div>
                                                                    <div class="flex flex-col gap-2">
                                                                        <Label For=@($"tfilter-{index + 1}")>
                                                                            Valor
                                                                        </Label>
                                                                        <Input Type="text"
                                                                                Id=@($"tfilter-{index + 1}")
                                                                                Name=@($"text-filter-{index + 1}")
                                                                                Placeholder="Nombre de columna"
                                                                                Disabled=@string.IsNullOrWhiteSpace(filter.Campo)
                                                                                Autocomplete="off"
                                                                                Value="@filter.Valor"
                                                                                ValueChanged="@((string val) => OnFilterValueChanged(filter, val))"
                                                                                Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                                                                                Style="height: calc(var(--spacing) * 8) !important;" />
                                                                    </div>
                                                                    <Button 
                                                                        Variant="outline" 
                                                                        Size="sm" 
                                                                        Class="text-red-600 hover:text-red-800 hover:bg-red-50 dark:hover:bg-red-900/20  dark:hover:border-red-900/50  cursor-pointer"
                                                                        Style="height: calc(var(--spacing) * 8) !important;"
                                                                        OnClick="() => RemoveFilter(filter)"
                                                                        >
                                                                      <Trash2 Class="w-4 h-4" />
                                                                    </Button>
                                                                </div>
                                                            </Card>
                                                        </div>
                                                    }
                                                }
                                            </CardContent>
                                        </Card>
                                    </TabsContent>

                                    <TabsContent Value="metrics">
                                        <Card Class=@($"shadow-xl border-gray-200 dark:border-gray-600 bg-white/80 dark:bg-gray-800/90 hover:shadow-md transition-shadow {(IsSelectClosed ? "backdrop-blur-sm" : "")}")>
                                            <CardHeader>
                                                <div class="flex items-center justify-between">
                                                    <div>
                                                        <CardTitle Class="flex items-center gap-2">
                                                            <TrendingUp Class="w-5 h-5" />
                                                            Métricas
                                                        </CardTitle>
                                                        <p class="text-sm text-[hsl(var(--muted-foreground))]">
                                                            Acá puedes agregar metricas como sumas, porcentajes, etc.
                                                        </p>
                                                    </div>
                                                    <Button Variant="outline"
                                                            Size="sm"
                                                            Class="cursor-pointer"
                                                            Disabled=@string.IsNullOrWhiteSpace(BasesDatosSeleccionado!)
                                                            OnClick="() => AddMetric()"
                                                    >
                                                        <Plus Class="w-4 h-4 mr-2" />
                                                        Agregar Metricas
                                                    </Button>
                                                </div>
                                            </CardHeader>
                                            <CardContent Class="space-y-4">
                                                @if(Metrics.Count == 0){
                                                    <div class="text-center py-8 text-muted-foreground">
                                                        <TrendingUp Class="w-12 h-12 mx-auto mb-4 opacity-50" />
                                                        <p>No hay métricas configuradas</p>
                                                    </div>
                                                }
                                                else
                                                {
                                                    @foreach ((ReportMetrics metric, int index) in Metrics.Select((ReportMetrics metric, int index) => (metric, index)))
                                                    {
                                                        <div @key="metric.Id">
                                                            <Card Class=@($"shadow-xl border-gray-200 dark:border-gray-600 bg-white/80 dark:bg-gray-800/90 hover:shadow-md transition-shadow p-4 flex items-center gap-4") Id=@($"filter-{index + 1}")>
                                                                <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center">
                                                                    <span class="text-sm font-medium text-blue-600 dark:text-blue-400">
                                                                        @(index + 1)
                                                                    </span>
                                                                </div>
                                                                <div class="grid grid-cols-1 md:grid-cols-6 gap-4 items-end flex-1">
                                                                    <div class="flex flex-col gap-2">
                                                                        <Label For=@($"tetiqueta-{index + 1}")>
                                                                            Etiqueta (Nombre columna)
                                                                        </Label>
                                                                        <Input Type="text"
                                                                               Id=@($"tetiqueta-{index + 1}")
                                                                               Name=@($"text-etiqueta-{index + 1}")
                                                                               Placeholder="Nombre de la metrica"
                                                                               Autocomplete="off"
                                                                               Value="@metric.Etiqueta"
                                                                               ValueChanged="@((string val) => OnMetricValueChanged(metric, val))"
                                                                               Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                                                                               Style="height: calc(var(--spacing) * 8) !important;" />
                                                                    </div>
                                                                    <div class="flex flex-col gap-2">
                                                                        <Label For=@($"baseTableFilter-{index + 1}")>
                                                                            Tabla
                                                                        </Label>
                                                                        <Select TItem="string"
                                                                                Items="@OptionsBasesDatosFilter"
                                                                                Id=@($"baseTableFilter-{index + 1}")
                                                                                Value="@metric.Tabla"
                                                                                ValueChanged="v => OnBasesDatosMetricSelectedChanged(metric, v)!"
                                                                                Placeholder="Selecciona la base de datos"
                                                                                ItemTextSelector="x => x"
                                                                                Disabled=@string.IsNullOrWhiteSpace(BasesDatosSeleccionado!)
