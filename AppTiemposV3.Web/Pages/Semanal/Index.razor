@page "/app/semanal"
@using AppTiemposV3.SharedClases.DTOs.Activities
@using AppTiemposV3.SharedClases.Enums
@using AppTiemposV3.Web.Pages.Requeriments.Modals

<PageTitle>
    Vista Semanal | TimeTracker Pro
</PageTitle>

<div class="flex flex-col w-full select-none">
    <Navbar Title="Vista Semanal" Subtitle="Calendario horizontal de actividades" OnToggleSidebar="HandleSidebarToggle">
        <div class="flex items-center gap-4 select-none">
            <Button Variant="outline" Size="sm" Class="cursor-pointer" OnClick="() => { PreviousWeek(); }">
                <ChevronLeft Class="w-4 h-4" />
            </Button>
            <span class="font-semibold text-gray-800 dark:text-gray-100">
                @weekRange
            </span>
            <Button Variant="outline" Size="sm" Class="cursor-pointer" OnClick="() => { NextWeek(); }" Disabled=@isNextDisabled>
                <ChevronRight Class="w-4 h-4" />
            </Button>
        </div>
    </Navbar>
    <article class="content px-4">
        <div class="px-6 space-y-6 mt-6">
            <Card Class=@($"shadow-xl border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/90  {(IsSelectClosed ? "backdrop-blur-sm" : "")}")>
                <CardHeader>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <CardTitle Class="text-lg flex items-center gap-2">
                                <Filter Class="w-5 h-5" />
                                Filtros Avanzados
                            </CardTitle>
                            @if (activeFiltersCount > 0)
                            {
                                <Badge Variant="secondary" Class="bg-blue-100 text-blue-800">
                                    @($"{activeFiltersCount} {Plural(activeFiltersCount, "activo", "activos")}")
                                </Badge>
                            }
                        </div>
                        <div className="flex items-center gap-2">
                            @if (activeFiltersCount > 0)
                            {
                                <Button Variant="outline" Size="sm" OnClick="() => LimpiarFiltros()"  Class="cursor-pointer">
                                    <Close Class="w-4 h-4 mr-1" />
                                    Limpiar
                                </Button>
                            }
                            <Button
                                Variant="ghost"
                                Size="sm"
                                Class="cursor-pointer"
                                OnClick="() => { isOpenFiltros = !isOpenFiltros; StateHasChanged(); }">
                                @if (!isOpenFiltros)
                                {
                                    <ChevronDown Class="w-4 h-4"/>
                                }
                                else
                                {
                                    <ChevronUp Class="w-4 h-4"/>
                                }
                            </Button>
                        </div>
                    </div>
                </CardHeader>

                @if (isOpenFiltros)
                {
                    <CardContent>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div>
                                <Label>
                                    Búsqueda General
                                </Label>
                                <div class="relative mt-2">
                                    <Search Class="absolute left-3 top-1/2 -translate-y-1/2 transform  text-gray-400 w-4 h-4 "/>
                                    <SearchInput
                                        @bind-Value="search"
                                        Placeholder="Buscar por descripción..."
                                        OnSearch="@DoSearch"
                                        Delay="400"
                                        Class="pl-10 pr-10 font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"/>
                                </div>
                            </div>

                            <div>
                                <Label For="reqId">REQ ID</Label>
                                <div class="relative mt-2">
                                    <FileText Class="absolute left-3 top-1/2 -translate-y-1/2 transform  text-gray-400 w-4 h-4 "/>
                                    <Input
                                        Id="reqId"
                                        @bind-value="@filterDto.reqID"
                                        Placeholder="ReqID123456"
                                        Class="pl-10 pr-10 font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                                    />
                                </div>
                            </div>
                            
                            <div>
                                <Label For="estadoSearch">Estado</Label>
                                <Select TItem="string"
                                        Items="@OptionsEstados"
                                        Id="estadoSearch"
                                        Value="EstadoSeleccionado"
                                        ValueChanged="OnEstadoSelectedChanged"
                                        Placeholder="Selecciona el estado"
                                        ItemTextSelector="x => x.ToString()"
                                        ClassButton=@($"mt-2 w-[25%] font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400")
                                        ClassOption=@($"w-[25%] font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400")
                                        EnableSearch="false"
                                        HeightClass="max-h-[120px]"
                                        OnDropdownStateChanged="HandleDropdownState"
                                >
                                </Select>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                            <div>
                                <Label For="dateIn" Id="dateLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                    Fecha Desde
                                </Label>
                                <CalendarFilterView 
                                    Id="dateIn" 
                                    weekNumber=@weekNumberSelected 
                                    Mode="CalendarMode.Single" 
                                    AllowFutureDates="false"
                                    OnDateSelected="DateChangedFrom" 
                                    OnDropdownStateChanged="HandleDropdownState" 
                                    ClassDiv="w-full" 
                                    ClassButton="w-full font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 h-10  px-3 py-2"
                                    />
                            </div>

                            <div>
                                <Label For="dateHasta" Id="dateHastaLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                    Fecha Hasta
                                </Label>
                                <CalendarFilterView 
                                    Id="dateHasta" 
                                    weekNumber=@weekNumberSelected 
                                    Mode="CalendarMode.Single" 
                                    Disabled=@(filterDto.dateFrom is null)
                                    OnDateSelected="DateChangedTo" 
                                    OnDropdownStateChanged="HandleDropdownState" 
                                    ClassDiv="w-full" 
                                    ClassButton="w-full font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 h-10  px-3 py-2"
                                    />
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                            <div>
                                <Label For="timeMin" Id="timeMinLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                    Horas Minimas
                                </Label>
                                <Input
                                    Type="number"
                                    @bind-Value="StartTimeString"
                                    InputMode="number"
                                    Id="timeMin"
                                    Name="hsMin"
                                    Placeholder="Horas Minimas"
                                    Autocomplete="off"
                                    Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                                />
                            </div>

                            <div>
                                <Label For="timeMax" Id="timeMaxLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                                    Horas Maximas
                                </Label>
                                <Input
                                    Type="number"
                                    InputMode="number"
                                    @bind-Value="EndTimeString"
                                    Id="timeMax"
                                    Disabled=@(filterDto.timeFrom is null)
                                    Name="hsmax"
                                    Placeholder="Horas Maximas"
                                    Autocomplete="off"
                                    Class="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                                />
                            </div>
                        </div>
                        <div class="flex justify-end items-center mt-4">
                            <Button
                                Variant="ghost"
                                Size="sm"
                                Class=@($"cursor-pointer {ColorService.GetButtonClassess()}")
                                OnClick="async () => await FilterSearch()"
                                Disabled=@isLoadingFiltros
                                >
                                @if (isLoadingFiltros)
                                {
                                    <LoaderCircle Class="mr-3 size-5 animate-spin" />
                                    <span>Filtrando...</span>
                                }
                                else
                                {
                                    <Filter Class="w-4 h-4 mr-2 size-5"/>
                                    <span>Filtrar</span>
                                }
                            </Button>
                        </div>
                    </CardContent>
                }
            </Card>
            
            <Card Class="shadow-xl border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/90  backdrop-blur-sm z-40">
                <CardHeader>
                    <div class="flex justify-between items-center">
                        <div class="flex-1">
                            <CardTitle>
                                Semana de @weekRange @*9hs a 18hs*@
                            </CardTitle>
                        </div>
                    </div>
                </CardHeader>
                <CardContent>
                    @* Contenido *@
                    @if (IsLoading)
                    {
                        <div class="flex flex-col items-center justify-center py-12 text-center">
                            <LoaderCircle Class="w-16 h-16 mb-4 animate-spin"/>
                            <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">
                                Cargando actividades
                            </h3>
                            <p class="text-gray-500 dark:text-gray-400 mb-4 animate-pulse">
                                Espere unos segundos ...
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="space-y-4 select-none">
                            @foreach (ActivitiesByDay? day in Activities)
                            {
                                string status = GetDayStatus(day);
                                
                                <div class="border border-gray-300 dark:border-gray-700 rounded-lg p-4 space-y-3">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-4">
                                            <div class="min-w-0">
                                                <h3 class="font-semibold text-gray-800 dark:text-gray-300">@day.DayName</h3>
                                                <p class="text-sm text-gray-600 dark:text-gray-500">@day.DayNameAndDay</p>
                                            </div>
                                            <div class="w-3 h-3 rounded-full" style="background-color: @GetStatusColor(status);"></div>
                                        </div>
                                        <div class="text-right">
                                            <p class="font-semibold text-gray-800 dark:text-gray-300">@day.Worked.ToString(@"hh\:mm")</p>
                                            <p class="text-sm text-gray-500">Total</p>
                                        </div>
                                    </div>

                                    @if (day.Activities.Count == 0)
                                    {
                                        <div class="text-center py-8 text-gray-500 dark:text-gray-300">
                                            <Clock Class="w-8 h-8 mx-auto mb-2 opacity-50" />
                                            <p>
                                                @(activeFiltersCount > 0 ? "Sin resultados para el filtro..." : "Sin actividades registradas")
                                            </p>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="space-y-2">
                                            @foreach (ActivityResponseDto act in day.Activities)
                                            {
                                                <div id="@act.Id" class="flex items-center gap-4 p-3 bg-gray-50 rounded-lg hover:bg-gray-100 border border-gray-200 dark:border-gray-600  dark:bg-gray-700 dark:hover:bg-gray-800 transition-colors">
                                                    <div class="flex items-center gap-2 min-w-0 flex-1">
                                                        <Clock Class="w-4 h-4 text-gray-400 flex-shrink-0" />
                                                        <span class="text-sm text-gray-600 dark:text-gray-400">
                                                            @act.StartTime - @act.EndTime
                                                        </span>
                                                    </div>

                                                    <Button
                                                        Variant="ghost"
                                                        Size="sm"
                                                        Class="text-blue-600 hover:text-blue-800 hover:bg-blue-50 dark:hover:bg-blue-900/20 font-medium p-0 h-auto justify-start cursor-pointer"
                                                        OnClick="@(() => ShowModal(act.Requeriment.Id))"
                                                    >
                                                        @($"ReqID{act.Requeriment.ReqID}")
                                                        <ExternalLink Class="w-3 h-3 ml-1" />
                                                    </Button>

                                                    <div class="min-w-0 flex-1">
                                                        <p class="text-sm font-medium text-gray-800 dark:text-gray-300 truncate">
                                                            @act.Description
                                                        </p>
                                                    </div>

                                                    <Badge Variant="secondary" Class="bg-blue-100 text-blue-800">
                                                        @act.TimeElapsed
                                                    </Badge>

                                                    <div>
                                                        <Enlace
                                                            Href=@($"/app/actividad/{act.UrlIndetificator}")
                                                            Target="_self"
                                                            Rel="noopener noreferer"
                                                            Class="border h-9 px-3 text-sm flex items-center justify-center rounded-md font-medium transition-colors focus:outline-none focus:ring-0 focus:ring-offset-0 disabled:opacity-50 disabled:pointer-events-none text-gray-400 hover:text-gray-100  dark:text-gray-300 dark:border-gray-500 dark:bg-gray-600  hover:bg-green-800/20 hover:border-green-900/50 cursor-pointer">
                                                                <Eye Class="w-4 h-4 mr-2"/>
                                                                Ver actividad
                                                        </Enlace>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </CardContent>
            </Card>
            @* Modales *@
            <ShowRequeriment @ref="showModalRef" />
        </div>
    </article>
</div>