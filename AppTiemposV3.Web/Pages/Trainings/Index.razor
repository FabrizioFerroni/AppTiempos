@using AppTiemposV3.SharedClases.DTOs.Trainings
@using static AppTiemposV3.Web.Utils.Helpers;
@using AppTiemposV3.Web.Pages.Requeriments.Modals
@using AppTiemposV3.Web.Pages.Trainings.Modales

@page "/app/capacitaciones"

<PageTitle>
    Capacitaciones | TimeTracker Pro
</PageTitle>

<div class="flex flex-col w-full select-none">
    <Navbar Title="Gestión de Capacitaciones" Subtitle="Administra y da seguimiento a las capacitaciones que te bridan" OnToggleSidebar="HandleSidebarToggle">
        <div class="flex items-center gap-4 select-none">
            <Button
                Class="@ColorService.GetButtonClassess()"
                OnClick="@(() => NewModal())"
                Disabled=@(IsLoading)
            >
                <Plus Class="h-4 w-4 mr-2"/>
                Nueva capacitación
            </Button>
        </div>
    </Navbar>
    <article class="content px-4">
        <div class="px-6 space-y-6 mt-6">
            @* Tarjeta de resumenes *@
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <Card Class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/25 dark:to-blue-800/30 border-blue-200 dark:border-blue-500/40">
                    <CardContent Class="pt-6">
                        <div class="flex items-center gap-3">
                            <GraduationCap Class="w-8 h-8 text-blue-600 dark:text-blue-400" />
                            <div>
                                <p class="text-sm font-medium text-blue-800 dark:text-blue-300">
                                    Total
                                </p>
                                <p class="text-2xl font-bold text-blue-900 dark:text-blue-100">
                                    @if (IsLoadingKpis)
                                    {
                                        <LoaderCircle Class="w-4 h-4 mb-2 animate-spin"/>
                                    }
                                    else
                                    {
                                        <span>
                                            @kpis.TotalTrainings
                                        </span>
                                    }
                                </p>
                            </div>
                        </div>
                    </CardContent>
                </Card>

                <Card Class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/25 dark:to-green-800/30 border-green-200 dark:border-green-500/40">
                    <CardContent Class="pt-6">
                        <div class="flex items-center gap-3">
                            <CheckCircle Class="w-8 h-8 text-green-600 dark:text-green-400" />
                            <div>
                                <p class="text-sm font-medium text-green-800 dark:text-green-300">
                                    Completadas
                                </p>
                                <p class="text-2xl font-bold text-green-900 dark:text-green-100">
                                    @if (IsLoadingKpis)
                                    {
                                        <LoaderCircle Class="w-4 h-4 mb-2 animate-spin"/>
                                    }
                                    else
                                    {
                                        <span>
                                            @kpis.TrainingCompleted
                                        </span>
                                    }
                                </p>
                            </div>
                        </div>
                    </CardContent>
                </Card>

                <Card Class="@($"{(theme == "dark" ? "card-progress-dark" : "card-progress-light")}")">
                    <CardContent Class="pt-6">
                        <div class="flex items-center gap-3">
                            <Clock Class="w-8 h-8 text-yellow-600 dark:text-yellow-400" />
                            <div>
                                <p class="text-sm font-medium text-yellow-800 dark:text-yellow-300">
                                    En Progreso
                                </p>
                                <p class="text-2xl font-bold text-yellow-900 dark:text-yellow-100">
                                    @if (IsLoadingKpis)
                                    {
                                        <LoaderCircle Class="w-4 h-4 mb-2 animate-spin"/>
                                    }
                                    else
                                    {
                                        <span>
                                            @kpis.TrainingInProgress
                                        </span>
                                    }
                                </p>
                            </div>
                        </div>
                    </CardContent>
                </Card>

                <Card Class="bg-gradient-to-br from-orange-50 to-orange-100 dark:from-orange-900/25 dark:to-orange-800/30 border-orange-200 dark:border-orange-500/40">
                    <CardContent Class="pt-6">
                        <div class="flex items-center gap-3">
                            <Clock Class="w-8 h-8 text-orange-600 dark:text-orange-400" />
                            <div>
                                <p class="text-sm font-medium text-orange-800 dark:text-orange-300">
                                    Tiempo Cargado
                                </p>
                                <p class="text-2xl font-bold text-orange-900 dark:text-orange-100">
                                    @if (IsLoadingKpis)
                                    {
                                        <LoaderCircle Class="w-4 h-4 mb-2 animate-spin"/>
                                    }
                                    else
                                    {
                                        <span>
                                            @kpis.TrainingIsLoaded
                                        </span>
                                    }
                                </p>
                            </div>
                        </div>
                    </CardContent>
                </Card>
            </div>
            @* Fin Tarjeta de resumenes *@
            @* Filtros *@
            <Card Class=@($"shadow-xl border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/90  {(IsSelectClosed ? "backdrop-blur-sm" : "")}")>
                <CardHeader>
                    <CardTitle>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <CardTitle Class="text-lg flex items-center gap-2">
                                    <Filter Class="w-5 h-5" />
                                    Filtros Avanzados
                                </CardTitle>
                                @if (activeFiltersCount > 0)
                                {
                                    <Badge Variant="secondary" Class="bg-blue-100 text-blue-800">
                                        @($"{activeFiltersCount} {Plural(activeFiltersCount, "activo", "activos")}")
                                    </Badge>
                                }
                            </div>
                            <div class="flex items-center gap-2">
                                @if (activeFiltersCount > 0)
                                {
                                    <Button Variant="outline" Size="sm" OnClick="() => LimpiarFiltros()"  Class="cursor-pointer">
                                        <Close Class="w-4 h-4 mr-1" />
                                        Limpiar
                                    </Button>
                                }
                                <Button
                                    Variant="ghost"
                                    Size="sm"
                                    Class="cursor-pointer"
                                    OnClick="() => { isOpenFiltros = !isOpenFiltros; StateHasChanged(); }">
                                    @if (!isOpenFiltros)
                                    {
                                        <ChevronDown Class="w-4 h-4"/>
                                    }
                                    else
                                    {
                                        <ChevronUp Class="w-4 h-4"/>
                                    }
                                </Button>
                            </div>
                        </div>
                    </CardTitle>
                </CardHeader>
                @if (isOpenFiltros)
                {
                    <CardContent>
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                            <div class="flex flex-col gap-4 items-start">
                                <Label For="estado" Id="estadoLabel">
                                    Estado
                                </Label>
                                <Select TItem="string"
                                        Items="@OptionsEstados"
                                        Id="estado"
                                        Value="EstadoSeleccionado"
                                        ValueChanged="OnEstadoSelectedChanged!"
                                        Placeholder="Selecciona el estado de la capacitación"
                                        ItemTextSelector="x => x.ToString()"
                                        ClassButton=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400")
                                        ClassOption=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400")
                                        EnableSearch="false"
                                        HeightClass="max-h-[120px]"
                                        OnDropdownStateChanged="HandleDropdownState">
                                </Select>
                            </div>

                            <div class="flex flex-col gap-4 items-start">
                                <Label Id="capacitadorLabel" For="capacitador">
                                    Capacitador
                                </Label>
                                <div class="relative w-full">
                                    <User Class="absolute left-3 top-3 h-4 w-4 text-gray-400 dark:text-gray-500"/>
                                    <Input
                                        Id="capacitador"
                                        @bind-Value=@filtrosForm.Capacitador
                                        Placeholder="Busque por nombre de capacitador"
                                        Class="pl-10 pr-10 font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"/>
                                </div>
                            </div>

                            <div class="flex flex-col gap-4 items-start">
                                <Label Id="loadedLabel" For="loaded">
                                    Tiempo cargado
                                </Label>
                                <Select TItem="string"
                                        Items="@OptionsCargados"
                                        Id="loaded"
                                        Value="LoadedSeleccionado"
                                        ValueChanged="OnLoadedSelectedChanged!"
                                        Placeholder="Selecciona si fue cargado o no"
                                        ItemTextSelector="x => x.ToString()"
                                        ClassButton=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400")
                                        ClassOption=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400")
                                        EnableSearch="false"
                                        HeightClass="max-h-[120px]"
                                        OnDropdownStateChanged="HandleDropdownState">
                                </Select>
                            </div>

                            <div class="flex flex-col gap-4 items-start">
                                <Label Id="reqIdLabel" For="reqId">
                                    ReqID
                                </Label>
                                <div class="relative w-full">
                                    <FileText Class="absolute left-3 top-3 h-4 w-4 text-gray-400 dark:text-gray-500"/>
                                    <Input
                                        Id="reqId"
                                        MaxLength="6"
                                        MinLength="1"
                                        Max="9"
                                        Min="1"
                                        @bind-Value=@filtrosForm.ReqId
                                        Pattern="^[0-9]*$"
                                        Placeholder="Busque por numero de requerimiento (6 digitos)"
                                        DigitsOnly
                                        Class="pl-10 pr-10 font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"/>
                                </div>
                            </div>
                        </div>
                        <div class="flex justify-end items-center mt-4">
                            <Button
                                Variant="ghost"
                                Size="sm"
                                Class=@($"cursor-pointer {ColorService.GetButtonClassess()}")
                                OnClick="async () => await FilterSearch()"
                                Disabled=@isLoadingFiltros
                            >
                                @if (isLoadingFiltros)
                                {
                                    <LoaderCircle Class="mr-3 size-5 animate-spin" />
                                    <span>Filtrando...</span>
                                }
                                else
                                {
                                    <Filter Class="w-4 h-4 mr-2 size-5"/>
                                    <span>Filtrar</span>
                                }
                            </Button>
                        </div>
                    
                    </CardContent>
                }
            </Card>
            @* Fin filtros *@
            @* Tabla *@
            <Card Class="shadow-xl border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/90  backdrop-blur-sm z-40">
                <CardHeader>
                    <div class="flex justify-between items-center">
                        <div class="flex-1">
                            <CardTitle>
                                Lista de Capacitaciones
                            </CardTitle>
                        </div>

                        <div class="flex justify-end items-center gap-3">
                            @if (!IsLoading)
                            {
                                <div class="w-16">
                                        <Select TItem="int"
                                                Items="@OptionsPaginated"
                                                Value="@registrosPorPagina"
                                                ValueChanged="OnPaginatedSelectedChanged"
                                                Placeholder="Paginado"
                                                ItemTextSelector="x => x.ToString()"
                                                ClassButton="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500"
                                                ClassOption="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500">
                                        </Select>
                                    </div>
                                    <div class="w-44">
                                        <Select TItem="string"
                                                Items="@OptionsOrders"
                                                Value="@ordenar"
                                                ValueChanged="OnOrderSelectedChanged!"
                                                Placeholder="Ordenar por"
                                                ItemTextSelector="x => x"
                                                ClassButton="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500"
                                                ClassOption="font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500">
                                        </Select>
                                    </div>
                                    <div>
                                        <Button 
                                            OnClick="() => OnAscendingChanged()"
                                            Variant=""
                                            Size=""
                                            Class="flex h-10 w-full items-center justify-between rounded-md border px-3 py-2 text-sm focus:outline-none disabled:cursor-not-allowed disabled:opacity-50  cursor-pointer font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white dark:hover:bg-gray-500">
                                            @if (ascending)
                                            {
                                                <ArrowUpAz Class="h-4 w-4" />
                                            }
                                            else
                                            {
                                                <ArrowDownAz Class="h-4 w-4" />
                                            }
                                        </Button>
                                    </div>
                            }
                        </div>
                    </div>
                </CardHeader>
                <CardContent>
                    @if (IsLoading)
                    {
                        <div class="flex flex-col items-center justify-center py-12 text-center">
                            <LoaderCircle Class="w-16 h-16 mb-4 animate-spin"/>
                            <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">
                                Cargando capacitaciones
                            </h3>
                            <p class="text-gray-500 dark:text-gray-400 mb-4 animate-pulse">
                                Espere unos segundos ...
                            </p>
                        </div>
                    }
                    else
                    {
                        @if (Trainings.Count == 0 && !SearchEmpty)
                        {
                            <div class="flex flex-col items-center justify-center py-12 text-center">
                                <GraduationCap Class="w-16 h-16 mb-4 text-gray-400"/>
                                <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">
                                    No hay capacitaciones
                                </h3>
                                <p class="text-gray-500 dark:text-gray-400 mb-4">
                                    No tienes capacitaciones registradas
                                </p>
                                <Button 
                                    Class="@ColorService.GetButtonClassess()"
                                    OnClick="@(() => NewModal())"
                                    Disabled=@(IsLoading)
                                >
                                    <Plus class="w-4 h-4 mr-2"/>
                                    Registrar primera capacitación
                                </Button>
                            </div>
                        }
                        else if (Trainings.Count == 0 && SearchEmpty)
                        {
                            <div class="flex flex-col items-center justify-center py-12 text-center">
                                <SearchX Class="w-16 h-16 mb-4 text-gray-400"/>
                                <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">
                                    No se han encontrado resultados para: <span class="font-bold">@filtroSelected</span> 
                                </h3>
                                <p class="text-gray-500 dark:text-gray-400 mb-4">
                                    Prueba de otra forma u con otro criterio.
                                </p>
                            </div>
                        }
                        else
                        {
                            <div class="space-y-4">
                                @foreach (TrainingResponseDto? item in Trainings)
                                {
                                    <div id="@item.Id" class="flex items-start justify-between p-4 border border-gray-200 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-700  transition-colors">
                                        <div class="flex-1 grid grid-cols-1 md:grid-cols-7 gap-4 items-center">
                                            <div>
                                                <p class="text-sm text-gray-500 dark:text-gray-400">
                                                    Fecha
                                                </p>
                                                <p class="font-medium text-gray-800 dark:text-gray-100">
                                                    @item.StartDate
                                                </p>
                                            </div>

                                            <div>
                                                <p class="text-sm text-gray-500 dark:text-gray-400">
                                                    REQ ID
                                                </p>
                                                <p class="font-medium text-blue-600 dark:text-blue-400">
                                                    @* @item.Requeriment.ReqIDDesc *@
                                                    <Button
                                                        Variant="ghost"
                                                        Size="sm"
                                                        Class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/20 font-medium p-0 h-auto justify-start cursor-pointer"
                                                        Style="padding: 0 !important;"
                                                        OnClick="@(() => ShowModal(item.Requeriment.Id))"
                                                    >
                                                        @item.Requeriment.ReqIDDesc
                                                        <Eye Class="w-3 h-3 ml-1" />
                                                    </Button>
                                                </p>
                                            </div>

                                            <div class="md:col-span-2">
                                                <p class="text-sm text-gray-500 dark:text-gray-400">
                                                    Descripción
                                                </p>
                                                <p class="font-medium text-gray-800 dark:text-gray-100 truncate">
                                                    @item.Description
                                                </p>
                                            </div>

                                            <div>
                                                <p class="text-sm text-gray-500 dark:text-gray-400">
                                                    Capacitador
                                                </p>
                                                <p class="font-medium text-gray-800 dark:text-gray-100">
                                                    @item.Capacitator
                                                </p>
                                            </div>

                                            <div>
                                                <p class="text-sm text-gray-500 dark:text-gray-400">
                                                    Horario
                                                </p>
                                                <p class="font-medium text-gray-800 dark:text-gray-100">
                                                    @item.StartTime @($"{(item.EndTime is not null ? $"- {item.EndTime}" : "- #:##" )}")
                                                </p>
                                                @if (item.TimeElapsed is not null)
                                                {
                                                    <p class="text-sm text-gray-600 dark:text-gray-300">(@item.TimeElapsed)</p>
                                                }
                                            </div>

                                            <div>
                                                <p class="text-sm text-gray-500 dark:text-gray-400">
                                                    Estado
                                                </p>
                                                <span class="@($"inline-flex items-center px-2 py-1 rounded-full text-xs font-medium {GetStatusColor(item.Status)}")">
                                                  @GetStatusNameR(item.Status)
                                                </span>
                                                <div class="flex items-center gap-1 mt-1">
                                                    @if (item.IsLoaded)
                                                    {
                                                        <CheckCircle Class="w-3 h-3 text-green-500"/>
                                                        <span class="text-xs text-green-600 dark:text-green-400">
                                                            Tiempo cargado
                                                        </span>
                                                    } else{
                                                        <XCircle Class="w-3 h-3 text-red-500"/>
                                                        <span class="text-xs text-red-600 dark:text-red-400">
                                                            Sin cargar
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <div class="flex gap-2">
                                            <Button
                                                Variant="outline"
                                                Size="sm"
                                                Id=@($"eye-{item.Id}")
                                                OnClick="() => ShowTrainingModal(item.Id)"
                                                Class="text-gray-400  dark:text-gray-300 dark:border-gray-500 dark:bg-gray-600  dark:hover:bg-green-800/20 dark:hover:border-green-900/50 cursor-pointer">
                                                <Eye Class="w-4 h-4"/>
                                            </Button>
                                            <Button
                                                Variant="outline"
                                                Size="sm"
                                                Class="text-gray-400 dark:text-gray-300 dark:border-gray-500 dark:bg-gray-600  dark:hover:bg-blue-800/20 dark:hover:border-blue-900/50 cursor-pointer"
                                                Id=@($"edit-btn-{item.Id}")
                                                OnClick="@(() => EditModal(item.Id))"
                                                >
                                                <Edit Class="w-4 h-4"/>
                                            </Button>
                                            <Button
                                                Variant="outline"
                                                Size="sm"
                                                Id=@($"delete-button-{item.Id}")
                                                OnClick="@(() => DeleteModal(item.Id, item.Requeriment.ReqID))"
                                                Class="text-red-600 hover:text-red-800 hover:bg-red-50 dark:hover:bg-red-900/20 dark:border-gray-500 dark:hover:border-red-900/50 dark:bg-gray-600  cursor-pointer">
                                                <Trash2 Class="w-4 h-4"/>
                                            </Button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }

                    @if (!IsLoading || !IsLoadingBackend || !IsLoadingDelete)
                    {
                        <Paginado T="TrainingResponseDto"
                                  Content="Trainings"
                                  PageNumber="pagina"
                                  Size="registrosPorPagina"
                                  TotalElements="totalElements"
                                  CurrentPage="currentPage"
                                  TotalPages="totalPages"
                                  MaxVisiblePages="maxVisiblePages"
                                  IsFirst="isFirst"
                                  IsLast="isLast"
                                  ShowCantPages="!IsLoadingBackend"
                                  FirstPage="First"
                                  LastPage="Last"
                                  RewindPage="Rewind"
                                  ForwardPage="Forward"
                                  OnSetPage="SetPage" />

                    }
                </CardContent>
            </Card>
            @* Fin Tabla *@
            <ShowRequeriment @ref="showModalRef" />
            <ShowTrainingModal @ref="showTModalRef" />
            <NewTrainingModal @ref="newModalRef" OnSaved="HandleActivitySaved" />
            <EditTrainingModal @ref=editModalRef OnSaved="HandleActivitySaved"/>
            <DeleteTrainingModal @ref="deleteModalRef" OnSaved="HandleActivityDeleted"/>
        </div>
    </article>
</div>
 