@using AppTiemposV3.SharedClases.Enums
<Modal Method="editRejection" IdElement="Id" Id=@($"dialog-modal-edit-rejection-{IdModalStr}") Class="select-none">
    <div class="px-6 my-4">
        <div class="flex justify-between items-center gap-3 mt-[-0.5rem]">
            <span class="text-gray-700 dark:text-gray-300 text-md">
                Editar rechazo
            </span>
            <Button
                Variant="ghost"
                Size="sm"
                Command="close"
                CommandFor=@($"editRejection-{Id}")
                Class="text-xs cursor-pointer"
            >
                <Close Class="dark:text-gray-300 text-gray-600 h-4 w-4"/>
            </Button>
        </div>

        @if (IsLoadingData)
        {
            <div class="flex flex-col items-center justify-center py-12 text-center">
                <LoaderCircle Class="w-16 h-16 mb-4 animate-spin text-gray-900 dark:text-gray-100"/>
                <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">
                    Cargando datos del rechazo para el requerimiento @ReqID
                </h3>
                <p class="text-gray-500 dark:text-gray-400 mb-4 animate-pulse">
                    Espere unos segundos ...
                </p>
            </div>
        }
        else
        {
            @if (isError)
            {
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 mb-3 rounded relative mt-2" role="alert">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
                    <div class="block sm:inline">
                        @messageError
                    </div>
                    <button type="button" class="absolute top-0 bottom-0 right-0 px-4 py-3 cursor-pointer" @onclick="() => { isError = false; StateHasChanged(); }">
                        <Close Class="h-6 w-6 text-red-500"/>
                    </button>
                </div>
            }
            
            
            <EditForm Enhance Model=@updateDto class="space-y-4 mt-4" novalidate OnValidSubmit=@SendEditReject FormName="EditRejectForm">
                <DataAnnotationsValidator/>

                <div>
                    <Label For="requerimiento" Id="reqIdLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                        REQ ID
                    </Label>
                    <Select TItem="string"
                            Items="@OptionsRequeriments"
                            Id="requerimiento"
                            Disabled
                            Value="@RequerimientoSeleccionado"
                            ValueChanged="OnRequerimentSelectedChanged!"
                            Placeholder="Selecciona un requerimiento"
                            ItemTextSelector="x => x"
                            ClassButton=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500")
                            ClassOption=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 dark:hover:bg-gray-500")
                            EnableSearch="true"
                            HeightClass="max-h-[70px]"
                    >
                    </Select>
                </div>
                

                <div class="space-y-2">
                    <Label Id="isLoadedLabelDesc" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                        ¿Resuelto por mí?
                    </Label>
                    <Switch Id="loaded" Checked=@updateDto.IsResolve CheckedChanged="HandleResolveCheck" Disabled="@(updateDto.Status == "completed")" />

                    <ValidationMessage For="() => updateDto.IsResolve" class="text-xs text-red-600"/>
                </div>
                
                @if (updateDto.IsResolve)
                {
                    <div class="space-y-2">
                        <Label For="resolvedDate" Id="resolvedDateLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                            Fecha que pasó a Testing
                        </Label>

                        <CalendarFilterView
                            Id="resolvedDate"
                            weekNumber="weekNumberSelected"
                            Mode="CalendarMode.Single"
                            OnDateSelected="DateChangedFrom"
                            OnDropdownStateChanged="HandleDropdownState"
                            SelectedStart="ResolvedDateForInput"
                            ClassDiv="w-full"
                            Disabled="@(updateDto.Status == "completed")"
                            With="w-full"
                            ClassHeight=@($"{(IsSelectClosed ? "": "h-[300px]")}")
                            ClassButton="w-full font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 h-10  px-3 py-2"
                        />
                        <ValidationMessage For="() => updateDto.ResolvedDate" class="text-xs text-red-600"/>
                    </div>
                }


                <div>
                    <Label For="statusRechazo" Id="statusRechazoLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">
                        Estado del rechazo
                    </Label>
                    <div class="relative">
                        <Select TItem="string"
                                Items="@OptionsEstados"
                                Id="statusRechazo"
                                Value="EstadoSeleccionado"
                                ValueChanged="OnEstadoSelectedChanged!"
                                Placeholder="Selecciona el estado del rechazo"
                                ItemTextSelector="x => x.ToString()"
                                ClassButton=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400")
                                ClassOption=@($"font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400")
                                EnableSearch="false"
                                OnDropdownStateChanged="HandleDropdownStatusState"
                                HeightClass="max-h-[120px]"
                                HeightClassPrin=@($"{(IsSelectClosedStatus ? "": "h-[130px]")}")
                        >
                        </Select>
                    </div>
                    <ValidationMessage For="() => updateDto.Status" class="text-xs text-red-600"/>
                </div>
                
                <div class="flex justify-end gap-2 pt-4">
                    <div class="flex gap-2">
                        <Button
                            Type="button"
                            Variant="outline"
                            Class="text-gray-700 dark:text-gray-300 cursor-pointer"
                            Command="close"
                            CommandFor="@($"editRejection-{Id}")"
                        >
                            <Close Class="w-4 h-4 mr-2" />
                            Cancelar
                        </Button>
                        <Button Type="submit" Disabled="@(IsLoadingEdit)"
                                Class=@($"{ColorService.GetButtonClassess()} text-white font-medium py-2.5 cursor-pointer")>

                            @if (IsLoadingEdit)
                            {
                                <LoaderCircle Class="mr-3 size-5 animate-spin" />
                                <span>Guardando...</span>
                            }
                            else
                            {
                                <Save Class="me-2 size-5" />
                                <span>
                                    Guardar
                                </span>
                            }
                        </Button>
                    </div>
                </div>
                
            </EditForm>
        }
    </div>
</Modal>

<button type="button" @ref="showModalRef" class="hidden" id=@($"showModalEdit-{Id}") command="show-modal" commandfor=@($"editRejection-{Id}")></button>      
<button type="button" @ref="closeModalRef" class="hidden" id=@($"closeModalEdit-{Id}") command="close" commandfor="@($"editRejection-{Id}")"></button> 