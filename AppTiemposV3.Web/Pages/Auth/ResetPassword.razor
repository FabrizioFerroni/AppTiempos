@page "/cambiar-clave/{Token}"

@layout MainLayout

<PageTitle>Cambiar Contraseña | TimeTracker Pro</PageTitle>

@if (IsSubmitted)
{
    <Card Class="w-full max-w-md shadow-xl border-0 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm">
        <CardHeader Class="text-center space-y-4">
            <div class="flex justify-center mb-4">
                <div class="w-16 h-16 bg-gradient-to-r from-green-500 to-emerald-600 rounded-2xl flex items-center justify-center">
                    <CheckCircleBig Class="w-8 h-8 text-white" />
                </div>
            </div>
            <div>
                <CardTitle Class="text-3xl font-bold bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">¡Contraseña Actualizada!</CardTitle>
                <CardDescription Class="text-lg text-gray-600 dark:text-gray-400">Tu contraseña ha sido cambiada exitosamente</CardDescription>
            </div>
        </CardHeader>
        <CardContent Class="space-y-6">
            <div class="text-center">
               <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
                    <p class="text-blue-800 dark:text-blue-200 text-sm">
                        🔒 <strong>Recomendación de seguridad:</strong>
                    </p>
                    <p class="text-blue-700 dark:text-blue-100 text-sm mt-1">
                        Asegúrate de usar una contraseña única y no compartirla con nadie
                    </p>
                </div>
            </div>

            <div class="text-center space-y-3">
                <Enlace
                    Href="/"
                    Class="w-full bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 text-white font-semibold py-2 px-4 rounded-md transition-all duration-200 shadow-lg hover:shadow-xl disabled:opacity-50  cursor-pointer"
                >
                    Iniciar sesión ahora
                </Enlace>

                <div class="text-center border-t border-gray-200 dark:border-gray-700 mt-8">
                    <p class="text-sm pt-4 text-gray-500 dark:text-gray-400 animate-pulse">Serás redirigido automáticamente en @segundos segundos ...</p>
                </div>
            </div>
        </CardContent>
    </Card>
}
else
{
    @if (!IsTokenValidAndNotExpired)
    {
        <Card Class="w-full max-w-md shadow-xl border-0 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm">
            <CardHeader Class="text-center space-y-4">
                <div class="flex justify-center mb-4">
                    <div class="w-16 h-16 bg-gradient-to-r from-red-500 to-red-600 rounded-2xl flex items-center justify-center">
                        <AlertCircle Class="w-8 h-8 text-white" />
                    </div>
                </div>
                <div>
                    <CardTitle Class="text-3xl font-bold bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">Token Inválido</CardTitle>
                    <CardDescription Class="text-lg text-gray-600 dark:text-gray-400">El enlace de recuperación no es válido o ha expirado</CardDescription>
                </div>
            </CardHeader>
            <CardContent Class="space-y-4">
                <div class="text-center text-gray-600 dark:text-gray-400">
                    <p class="m-0 p-0">El enlace que utilizaste no es válido o ha expirado.</p>
                    <p class="text-sm mt-2">
                        Por favor, solicita un nuevo enlace de recuperación.
                    </p>
                </div>

                <div class="text-center space-y-2">
                    <Enlace
                        Href="olvide-contrasena"
                        Class="w-full bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white font-semibold py-2 px-4 rounded-md transition-all duration-200 shadow-lg hover:shadow-xl disabled:opacity-50  cursor-pointer"
                    >
                        Solicitar Nuevo Enlace
                    </Enlace>
                </div>

                <div class="mt-8 text-center border-t border-gray-200 dark:border-gray-700">
                    <Enlace Href="/" Class="font-semibold text-gray-600 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 bg-transparent flex justify-center items-center pt-4">
                        <ArrowLeft Class="w-4 h-4 mr-2" />
                        Volver al inicio de sesión
                    </Enlace>
                </div>
            </CardContent>
        </Card>
    }
    else
    {
        <Card Class="w-full max-w-md shadow-xl border-0 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm">
            <CardHeader Class="text-center space-y-4">
                <div class="flex justify-center mb-4">
                    <div class="w-16 h-16 bg-gradient-to-r from-blue-500 to-purple-600 rounded-2xl flex items-center justify-center">
                        <RotateCcwKey Class="w-8 h-8 text-white" />
                    </div>
                </div>
                <div>
                    <CardTitle Class="text-3xl font-bold bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">Nueva Contraseña</CardTitle>
                    <CardDescription Class="text-lg text-gray-600 dark:text-gray-400">Ingresa tu nueva contraseña</CardDescription>
                </div>
            </CardHeader>
            <CardContent>
                @if (IsError)
                {
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 mb-3 rounded relative" role="alert">
                        <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
                        <div class="block sm:inline">
                            @messageError
                        </div>
                        <button type="button" class="absolute top-0 bottom-0 right-0 px-4 py-3 cursor-pointer" @onclick="() => { IsError = false; StateHasChanged(); }">
                            <Close Class="h-6 w-6 text-red-500" />
                        </button>
                    </div>
                }

                <EditForm Enhance Model=@resetPwd class="space-y-4" novalidate OnValidSubmit=@SendResetPassword FormName="ResetPasswordForm">
                    <DataAnnotationsValidator/>
                    <div class="space-y-2">
                        <Label For="passwordNew" Id="passwordNewLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">Nueva contraseña</Label>
                        <div class="relative">
                            <Input
                                Type="@(ShowPassword ? "text" : "password")"
                                @bind-Value="resetPwd.NewPassword"
                                Id="@(ShowPassword ? "new-password-show" : "new-password-hide")"
                                Name="new-password"
                                Placeholder="********"
                                Autocomplete="off"
                                Required
                                Class="pr-10 font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                            />
                            <ShowPassword @bind-IsVisible="ShowPassword"/>
                        </div>
                        <ValidationMessage For="() => resetPwd.NewPassword" class="text-xs text-red-600"/>
                    </div>
                    <div class="space-y-2">
                        <Label For="@(ShowPasswordConfirm ? "confirm-password-show" : "confirm-password-hide")" Id="passwordConfirmLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">Confirmar contraseña</Label>
                        <div class="relative">
                            <Input
                                Type="@(ShowPasswordConfirm ? "text" : "password")"
                                @bind-Value="resetPwd.ConfirmPassword"
                                Id="@(ShowPasswordConfirm ? "confirm-password-show" : "confirm-password-hide")"
                                Name="confirm-password"
                                Placeholder="********"
                                Autocomplete="off"
                                Required
                                Class="pr-10 font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                            />
                            <ShowPassword @bind-IsVisible="ShowPasswordConfirm"/>
                        </div>
                        <ValidationMessage For="() => resetPwd.ConfirmPassword" class="text-xs text-red-600"/>
                    </div>
                    <Button Type="submit"
                            Disabled="@(IsLoading || (resetPwd.NewPassword == "" || resetPwd.ConfirmPassword == ""))"
                            Class="w-full bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white font-semibold py-2 px-4 rounded-md transition-all duration-200 shadow-lg hover:shadow-xl disabled:opacity-50  cursor-pointer">

                        @if (IsLoading)
                        {
                            <LoaderCircle Class="mr-3 size-5 animate-spin" />
                            <span>Cambiando contraseña <span class="animate-pulse">...</span></span>
                        }
                        else
                        {
                            <RotateCcwKey Class="me-2 size-5" />
                            <span>Cambiar contraseña</span>
                        }
                    </Button>
                </EditForm>
                <div class="mt-6 text-center border-t border-gray-200 dark:border-gray-700">
                    <Enlace Href="/" Class="font-semibold text-gray-600 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 bg-transparent flex justify-center items-center pt-4">
                        <ArrowLeft class="w-4 h-4 mr-2" />
                        Volver al inicio de sesión
                    </Enlace>
                </div>
            </CardContent>
        </Card>
    }
}