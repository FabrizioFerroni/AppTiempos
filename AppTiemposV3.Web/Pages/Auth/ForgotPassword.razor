@page "/olvide-contrasena"

@layout MainLayout

<PageTitle>Olvide Contraseña | TimeTracker Pro</PageTitle>

@if (isSubmitted)
{
    <Card Class="w-full max-w-md bg-white/90 dark:bg-gray-800/90 backdrop-blur-sm border-gray-200 dark:border-gray-700 shadow-xl">
        <CardHeader Class="space-y-1 text-center">
            <div class="flex justify-center mb-4">
                <div class="w-16 h-16 bg-gradient-to-r from-green-500 to-emerald-600 rounded-2xl flex items-center justify-center">
                    <CheckCircleBig Class="w-8 h-8 text-white" />
                </div>
            </div>
            <CardTitle Class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
                Email Enviado
            </CardTitle>
            <CardDescription Class="text-gray-600 dark:text-gray-300 font-medium">
                Revisa tu bandeja de entrada para continuar
            </CardDescription>
        </CardHeader>

        <CardContent Class="space-y-4">
            <div class="p-4 bg-green-50 dark:bg-green-900/20 rounded-lg border border-green-200 dark:border-green-800">
                <p class="text-sm font-medium text-green-800 dark:text-green-200 text-center">
                    Hemos enviado un enlace de recuperación a <strong class="font-semibold">@forgotPwd.Email</strong>
                </p>
            </div>

            <div class="text-center space-y-2">
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">
                    ¿No recibiste el email? Revisa tu carpeta de spam o
                </p>
                <Button
                    variant="outline"
                    @onclick="() => { isSubmitted = !isSubmitted; }"
                    Class="font-semibold text-blue-600 dark:text-blue-700 border-blue-200 dark:border-blue-700 hover:bg-blue-50 dark:bg-blue-900/20 dark:hover:bg-blue-900/30 cursor-pointer"
                >
                Intentar con otro email
                </Button>
            </div>

            <div class="pt-4 text-center border-t border-gray-200 dark:border-gray-700">
                <Enlace Href="/" Class="font-semibold text-gray-600 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 bg-transparent flex justify-center items-center pt-4">
                    <ArrowLeft Class="w-4 h-4 mr-2" />
                    Volver al inicio de sesión
                </Enlace>
            </div>
        </CardContent>
    </Card>
}
else
{
    <Card Class="w-full max-w-md bg-white/90 dark:bg-gray-800/90 backdrop-blur-sm border-gray-200 dark:border-gray-700 shadow-xl">
        <CardHeader Class="space-y-1 text-center">
            <div class="flex justify-center mb-4">
                <div class="w-16 h-16 @ColorService.GetCurrentColor()!.Gradient rounded-2xl flex items-center justify-center">
                    <Mail Class="w-8 h-8 text-white" />
                </div>
            </div>
            <CardTitle Class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
                Recuperar Contraseña
            </CardTitle>
            <CardDescription Class="text-gray-600 dark:text-gray-300 font-medium">
                Ingresa tu email para recibir un enlace de recuperación
            </CardDescription>
        </CardHeader>
        <CardContent>
            @if (isError)
            {
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 mb-3 rounded relative" role="alert">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
                    <div class="block sm:inline">
                        @messageError
                    </div>
                    <button type="button" class="absolute top-0 bottom-0 right-0 px-4 py-3 cursor-pointer" @onclick="() => { isError = false; StateHasChanged(); }">
                        <Close Class="h-6 w-6 text-red-500" />
                    </button>
                </div>
            }

            <EditForm Enhance Model=@forgotPwd class="space-y-4" novalidate OnValidSubmit=@SendForgotPassword FormName="ForgotPasswordForm">
                <DataAnnotationsValidator/>
                <div class="space-y-2">
                    <Label For="email" Id="emailLabel" Class="text-gray-700 dark:text-gray-300 mb-3 block">Correo electrónico</Label>
                    <div class="relative">
                        <Input
                            Type="email"
                            @bind-Value="forgotPwd.Email"
                            Id="email"
                            Name="email"
                            Placeholder="jhon.doe@example.com"
                            Autocomplete="off"
                            Required
                            Class="pr-10 font-medium bg-white dark:bg-gray-700 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
                        />
                        <Mail Class="absolute right-3 top-3 h-4 w-4 text-gray-400 dark:text-gray-500" />
                    </div>
                    <ValidationMessage For="() => forgotPwd.Email" class="text-xs text-red-600"/>
                </div>
                <Button Type="submit"
                        Disabled="@(isLoading || !IsValidEmail(forgotPwd.Email))"
                        Class=@($"w-full {ColorService.GetCurrentColor()!.Gradient} {ColorService.GetCurrentColor()!.Hover} text-white font-semibold py-2 px-4 rounded-md transition-all duration-200 shadow-lg hover:shadow-xl disabled:opacity-50  cursor-pointer")>

                    @if (isLoading)
                    {
                        <LoaderCircle Class="mr-3 size-5 animate-spin" />
                        <span>Enviando enlace<span class="animate-pulse">...</span></span>
                    }
                    else
                    {
                        <Send Class="me-2 size-5" />
                        <span>Enviar Enlace de Recuperación</span>
                    }
                </Button>
            </EditForm>
            <div class="mt-6 text-center border-t border-gray-200 dark:border-gray-700">
                <Enlace Href="/" Class="font-semibold text-gray-600 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 bg-transparent flex justify-center items-center pt-4">
                    <ArrowLeft class="w-4 h-4 mr-2" />
                    Volver al inicio de sesión
                </Enlace>
            </div>
        </CardContent>
    </Card>
}